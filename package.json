{
  "name": "astn-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./*\" dev",
    "dev:cms": "pnpm --filter payload dev",
    "dev:web": "pnpm --filter astro dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
