---
import { Picture, getImage } from 'astro:assets';
import Base from '@layouts/Base.astro';
import Tag from '@components/Tag.astro';
import Chip from '@components/Chip.astro';
import Badge from '@components/Badge.astro';
import StatusIndicator from '@components/StatusIndicator.astro';
import Carousel, { type CarouselImage } from '@components/Carousel.astro';
import ShareButton from '@components/ShareButton.astro';
import CommentSection from '@components/comments/CommentSection.svelte';
import slugify from '@scripts/slugify';
import type { Status } from '@scripts/types';

type RemoteImage = {
  url: string;
  width: number;
  height: number;
  alt?: string;
};

type Props = {
  title: string;
  description: string;
  keywords?: string[];
  author?: string;
  coverImage?: ImageMetadata | RemoteImage;
  coverAlt?: string;
  images?: CarouselImage[];
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  categoryBase: string;
  tags?: string[];
  tagsBase: string;
  status?: Status;
  demoUrl?: string;
  repositoryUrl?: string;
  frontendmentorUrl?: string;
  postId?: string;
  payloadUrl?: string;
  postCollection?: string;
};

function isRemoteImage(
  img: ImageMetadata | RemoteImage | undefined,
): img is RemoteImage {
  return !!img && 'url' in img;
}

const {
  title,
  description,
  keywords,
  author,
  coverImage,
  coverAlt,
  images,
  pubDate,
  updatedDate,
  category,
  categoryBase,
  tags,
  tagsBase,
  status,
  demoUrl,
  repositoryUrl,
  frontendmentorUrl,
  postId,
  payloadUrl,
  postCollection = 'posts',
} = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';

const coverIsRemote = isRemoteImage(coverImage);
const ogImageData = coverImage
  ? await getImage({
      src: coverIsRemote ? coverImage.url : (coverImage as ImageMetadata),
      width: 1200,
      height: 630,
      format: 'png',
      inferSize: coverIsRemote,
    })
  : null;
const ogImage = ogImageData
  ? ogImageData.src.startsWith('http')
    ? ogImageData.src
    : `${siteUrl}${ogImageData.src}`
  : undefined;

const hasProjectLinks = !!demoUrl || !!repositoryUrl || !!frontendmentorUrl;
---

<Base {title} {description} {keywords} {author} {ogImage}>
  <div class='post-title-container'>
    {
      status && (
        <div class='status-indicator-container'>
          <StatusIndicator {status} />
        </div>
      )
    }
    <h1 class='post-title'>{title}</h1>
  </div>

  <div class='post-info-container'>
    <div class='post-date-info-container'>
      <div class='date-info-item'>
        <p class='published-label'>Date Published</p>
        <Chip icon='ri-calendar-line'>
          {
            pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </Chip>
      </div>
      {
        updatedDate && (
          <div class='date-info-item'>
            <p class='published-label'>Last Update</p>
            <Chip icon='ri-calendar-line'>
              {updatedDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </Chip>
          </div>
        )
      }
    </div>

    <div class='post-meta-row'>
      {
        category && (
          <Badge
            icon='ri-folder-3-line'
            url={`${categoryBase}/${slugify(category)}`}
          >
            {category}
          </Badge>
        )
      }
      {
        tags && (
          <ul class='tags-list'>
            {tags.map((tag) => (
              <li class='tags-list-item'>
                <Tag
                  label={tag}
                  style='simple'
                  url={`${tagsBase}/${slugify(tag)}`}
                />
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>

  {
    images ? (
      <div class='post-cover-container'>
        <Carousel {images} />
      </div>
    ) : coverImage && coverAlt ? (
      <div class='post-cover-container'>
        {coverIsRemote ? (
          <Picture
            src={coverImage.url}
            alt={coverAlt}
            width={coverImage.width}
            height={coverImage.height}
            class='post-cover'
          />
        ) : (
          <Picture
            src={coverImage as ImageMetadata}
            alt={coverAlt}
            class='post-cover'
          />
        )}
      </div>
    ) : (
      <div class='spacer' />
    )
  }

  <div class='post-heading-footer'>
    {
      hasProjectLinks && (
        <ul class='project-links-list'>
          {demoUrl && (
            <li>
              <a href={demoUrl} title='Live Demo' class='project-link'>
                <span class='visually-hidden'>Live Demo</span>
                <span class='ri-play-large-line' />
              </a>
            </li>
          )}
          {repositoryUrl && (
            <li>
              <a href={repositoryUrl} title='Repository' class='project-link'>
                <span class='visually-hidden'>Repository</span>
                <span class='ri-git-repository-line' />
              </a>
            </li>
          )}
          {frontendmentorUrl && (
            <li>
              <a
                href={frontendmentorUrl}
                title='Frontend Mentor Page'
                class='project-link'
              >
                <span class='visually-hidden'>Frontend Mentor Page</span>
                <span class='ri-pencil-ruler-2-line' />
              </a>
            </li>
          )}
        </ul>
      )
    }
    <div class='post-share-container'>
      <ShareButton {title} {description} />
    </div>
  </div>

  <article>
    <slot />
  </article>

  {
    postId && payloadUrl && (
      <div>
        <CommentSection client:load {payloadUrl} {postId} {postCollection} />
      </div>
    )
  }
</Base>

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  .post-title-container {
    display: flex;
    align-items: center;
    gap: 1rem;

    width: 100%;

    margin-top: 8rem;
  }

  .status-indicator-container {
    position: relative;
    left: 0.25rem;
    margin-top: 0.25rem;
  }

  .spacer {
    content: '';
    height: 2.5rem;
  }

  .post-heading-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;

    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  p.published-label {
    font-size: 0.85rem;
    margin: 0;
    color: var(--clr-text-2);
  }

  a.project-link {
    --size: 2.75rem;

    display: flex;
    align-items: center;
    justify-content: center;

    height: var(--size);
    width: var(--size);

    background-color: var(--clr-surface-0);

    color: var(--clr-text-1);
    font-size: 1.25rem;
    text-decoration: none;

    border-radius: 50%;
    outline-width: 0.1rem;
    outline-style: solid;
    outline-color: var(--clr-surface-1);

    transition-property: outline-color, color, background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  a.project-link:hover {
    background-color: var(--clr-surface-1);
    color: var(--clr-text-0);
    outline-color: var(--clr-overlay-0);
  }

  h1 {
    margin: 0;
    line-height: 1.75ch;
  }

  article {
    background-color: var(--clr-surface-0);
    padding-inline: 2rem;
    padding-block: 1rem;

    border-radius: 16pt;
  }

  .post-cover-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;

    margin-top: 1.5rem;
    overflow: hidden;
    border-radius: 16pt;
  }

  .post-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    width: 100%;
    height: auto;
    object-fit: cover;
    z-index: -1;
  }

  .post-info-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    padding-inline: 0.25rem;
    margin-top: 0.75rem;
  }

  .post-meta-row {
    display: flex;
    flex-direction: column;
    align-items: end;
    gap: 0.6rem;
  }

  ul.tags-list {
    display: flex;
    justify-content: end;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;

    padding: 0;
    margin: 0;

    list-style-type: none;
  }

  .post-date-info-container {
    display: flex;
    flex-shrink: 0;
    gap: 2rem;
  }

  .post-share-container {
    display: flex;
    align-items: center;
    justify-content: center;

    margin-left: auto;
  }

  ul.project-links-list {
    position: relative;
    left: -0.2rem;

    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;

    padding: 0;
    margin-top: 0;
    margin-bottom: 0;

    list-style-type: none;
  }

  @media screen and (width < $width-mobile-2) {
    h1 {
      font-size: 2rem;
    }

    article {
      padding: 0;
      background-color: transparent;
    }

    ul.tags-list {
      justify-content: start;
    }

    .post-title-container {
      flex-direction: column;
      align-items: start;
    }

    .post-share-container {
      margin-left: 0;
    }

    .post-info-container {
      flex-direction: column;
      align-items: start;
    }

    .post-meta-row {
      align-items: start;
    }
  }
</style>
