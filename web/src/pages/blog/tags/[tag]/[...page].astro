---
import { getCollection } from 'astro:content';
import type { Page } from 'astro';
import Directory from '@layouts/Directory.astro';
import blogBg from '@assets/images/blog-hero.jpg';
import { Collection } from '@scripts/types';
import slugify from '@scripts/slugify';

export async function getStaticPaths({ paginate }: any) {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];

  return tags.flatMap((tag) => {
    const filtered = posts.filter((p) => p.data.tags?.includes(tag));
    return paginate(filtered, {
      params: { tag: slugify(tag) },
      props: { tagName: tag },
      pageSize: 8,
    });
  });
}

type Props = {
  page: Page;
  tagName: string;
};

const { page, tagName } = Astro.props;
---

<Directory
  page={page}
  pageTitle={`Blog - Tags - ${tagName} | Austin Hagel`}
  collection={Collection.blog}
  heroTitle={tagName}
  heroSubtitle='Tag'
  heroSubtitleIcon='ri-price-tag-3-line'
  route='/blog'
  image={blogBg}
  showFeatured={false}
/>
