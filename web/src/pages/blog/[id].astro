---
import { getCollection } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';
import LexicalRenderer from '@components/lexical/LexicalRenderer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.archived)
    .map((post) => ({
      params: { id: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;

const keywords = [
  ...(post.data.category ? [post.data.category] : []),
  ...(post.data.tags ? post.data.tags : []),
];

const payloadBaseUrl =
  import.meta.env.PAYLOAD_URL ??
  import.meta.env.NEXT_PUBLIC_SERVER_URL ??
  'http://localhost:3000';
---

<PostLayout
  title={`${post.data.title} | Austin Hagel`}
  description={post.data.description}
  keywords={keywords}
  author={post.data.author}
  coverImage={post.data.coverImage}
  coverAlt={post.data.coverAlt}
  images={post.data.images}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  categoryBase='/blog/categories'
  tags={post.data.tags}
  tagsBase='/blog/tags'
  postId={post.data.payloadId}
  payloadUrl={payloadBaseUrl}
>
  <LexicalRenderer content={post.data.content} baseUrl={payloadBaseUrl} />
</PostLayout>
