---
import Base from '@layouts/Base.astro';
import DirectoryHero from '@components/DirectoryHero.astro';
import { getCollection } from 'astro:content';
import frontendProjectsBg from '@assets/images/projects.jpg';

const frontendProjects = await getCollection('frontendProjects');
const frontendCount = frontendProjects.length;

type Collection = {
  title: string;
  description: string;
  icon: string;
  accent: string;
  href?: string;
  count?: number;
  comingSoon?: boolean;
};

const collections: Collection[] = [
  {
    title: 'Frontend Development',
    description:
      'Interfaces, experiments and small apps — built with modern frameworks and a close eye on design details.',
    icon: 'ri-code-s-slash-line',
    accent: 'blue',
    href: '/projects/frontend',
    count: frontendCount,
  },
  {
    title: 'Graphic Design',
    description:
      'Posters, brand systems and visual identity work exploring type, color and composition.',
    icon: 'ri-artboard-line',
    accent: 'pink',
    href: '/projects/graphic-design',
    comingSoon: false,
  },
  {
    title: 'Backend Development',
    description:
      'APIs, services and infrastructure — the plumbing that makes everything else possible.',
    icon: 'ri-server-line',
    accent: 'aqua',
    comingSoon: true,
  },
  {
    title: '3D Modeling',
    description:
      'Renders, props and scenes built in Blender — where technical precision meets sculptural form.',
    icon: 'ri-shape-line',
    accent: 'orange',
    comingSoon: true,
  },
  {
    title: 'Art',
    description:
      'Sketches, illustrations and studies — the quieter corner of the portfolio where ideas begin.',
    icon: 'ri-brush-line',
    accent: 'purple',
    comingSoon: true,
  },
];
---

<Base
  title='Projects | Austin Hagel'
  description='Browse my project collections across frontend development, design, 3D and more.'
>
  <DirectoryHero
    title='Projects'
    titleIcon='ri-stack-line'
    image={frontendProjectsBg}
    description='A portfolio of work across disciplines — development, design and everything in between. Pick a collection below to explore.'
  />

  <div class='collections-intro'>
    <p class='section-title'>Browse Collections</p>
    <hr />
  </div>

  <ul class='collections-grid'>
    {
      collections.map((collection) => {
        const isActive = !collection.comingSoon;

        return (
          <li data-scroll-animate>
            {isActive ? (
              <a
                class='collection-card'
                data-active='true'
                data-accent={collection.accent}
                href={collection.href}
              >
                <div class='card-icon-area'>
                  <span
                    class={`card-icon ${collection.icon}`}
                    aria-hidden='true'
                  />
                </div>

                <div class='card-body'>
                  <div class='card-heading'>
                    <h2 class='card-title'>{collection.title}</h2>
                    <p class='card-meta card-meta--active'>
                      <span class='meta-dot' aria-hidden='true' />
                      {collection.count}{' '}
                      {collection.count === 1 ? 'project' : 'projects'}
                    </p>
                  </div>
                  <p class='card-description'>{collection.description}</p>
                </div>

                <div class='card-cta'>
                  <span class='cta-label'>Browse collection</span>
                  <span
                    class='cta-icon ri-arrow-right-line'
                    aria-hidden='true'
                  />
                </div>
              </a>
            ) : (
              <div
                class='collection-card'
                data-active='false'
                data-accent={collection.accent}
                aria-disabled='true'
              >
                <div class='card-icon-area'>
                  <span
                    class={`card-icon ${collection.icon}`}
                    aria-hidden='true'
                  />
                  <span class='card-icon-grid' aria-hidden='true' />
                </div>

                <div class='card-body'>
                  <div class='card-heading'>
                    <h2 class='card-title'>{collection.title}</h2>
                    <p class='card-meta card-meta--pending'>
                      <span
                        class='meta-dot meta-dot--pending'
                        aria-hidden='true'
                      />
                      Coming soon
                    </p>
                  </div>
                  <p class='card-description'>{collection.description}</p>
                </div>

                <div class='card-cta' aria-hidden='true'>
                  <span class='cta-label cta-label--pending'>In progress</span>
                </div>
              </div>
            )}
          </li>
        );
      })
    }
  </ul>
</Base>

<style lang='scss'>
  @use '../../styles/variables.scss' as *;

  /* ---------- Intro divider ---------- */
  .collections-intro {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .collections-intro hr {
    margin-top: 0.5rem;
  }

  /* ---------- Scroll animations ---------- */
  @media (prefers-reduced-motion: no-preference) {
    [data-scroll-animate] {
      opacity: 0;
      transform: translateY(1.5rem);

      transition:
        opacity 600ms ease-out,
        transform 600ms ease-out;
    }

    [data-scroll-animate].visible {
      opacity: 1;
      transform: translateY(0);
    }

    .collections-grid [data-scroll-animate]:nth-child(2) {
      transition-delay: 80ms;
    }
    .collections-grid [data-scroll-animate]:nth-child(3) {
      transition-delay: 160ms;
    }
    .collections-grid [data-scroll-animate]:nth-child(4) {
      transition-delay: 240ms;
    }
    .collections-grid [data-scroll-animate]:nth-child(5) {
      transition-delay: 320ms;
    }
  }

  /* ---------- Grid ---------- */
  ul.collections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;

    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
  }

  ul.collections-grid > li {
    display: flex;
  }

  /* ---------- Accent token map ---------- */
  .collection-card {
    --accent: var(--clr-blue);
  }
  .collection-card[data-accent='blue'] {
    --accent: var(--clr-blue);
  }
  .collection-card[data-accent='aqua'] {
    --accent: var(--clr-aqua);
  }
  .collection-card[data-accent='pink'] {
    --accent: var(--clr-pink);
  }
  .collection-card[data-accent='orange'] {
    --accent: var(--clr-orange);
  }
  .collection-card[data-accent='purple'] {
    --accent: var(--clr-purple);
  }

  /* ---------- Card ---------- */
  .collection-card {
    position: relative;
    isolation: isolate;

    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 1.25rem;

    width: 100%;
    padding: 1.5rem;

    background-color: var(--clr-surface-0);
    border: 1px solid var(--clr-surface-2);
    border-radius: 14pt;

    color: var(--clr-text-0);
    text-decoration: none;

    overflow: hidden;

    transition:
      transform 300ms ease-out,
      border-color 300ms ease-out,
      background-color 300ms ease-out,
      box-shadow 300ms ease-out;
  }

  /* Accent wash that intensifies on hover for active cards */
  .collection-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;

    background: radial-gradient(
      120% 70% at 0% 0%,
      oklch(from var(--accent) l c h / 0.08),
      transparent 60%
    );

    opacity: 0.6;

    transition: opacity 300ms ease-out;
  }

  a.collection-card {
    cursor: pointer;
  }

  a.collection-card:hover {
    transform: translateY(-3px);
    border-color: oklch(from var(--accent) l c h / 0.5);
    background-color: var(--clr-surface-1);
    box-shadow: 0 10px 30px -20px oklch(from var(--accent) l c h / 0.4);
  }

  a.collection-card:hover::before {
    opacity: 1;
  }

  a.collection-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Coming-soon state */
  .collection-card[data-active='false'] {
    cursor: not-allowed;

    background-color: oklch(from var(--clr-surface-0) l c h / 0.5);
    border-style: dashed;
    border-color: var(--clr-surface-2);
  }

  .collection-card[data-active='false'] .card-title,
  .collection-card[data-active='false'] .card-description {
    color: var(--clr-text-2);
  }

  /* ---------- Icon area ---------- */
  .card-icon-area {
    position: relative;

    display: flex;
    align-items: center;
    justify-content: center;

    aspect-ratio: 5 / 2;
    width: 100%;

    background: linear-gradient(
      135deg,
      oklch(from var(--accent) l c h / 0.12),
      oklch(from var(--accent) l c h / 0.04)
    );
    border: 1px solid oklch(from var(--accent) l c h / 0.2);
    border-radius: 8pt;

    overflow: hidden;
  }

  .collection-card[data-active='false'] .card-icon-area {
    background: linear-gradient(
      135deg,
      oklch(from var(--accent) l c h / 0.05),
      transparent
    );
    border-color: var(--clr-surface-2);
  }

  .card-icon {
    position: relative;
    z-index: 1;

    font-size: 3rem;
    color: var(--accent);

    transition:
      transform 400ms ease-out,
      color 300ms ease-out;
  }

  .collection-card[data-active='false'] .card-icon {
    color: oklch(from var(--accent) l c h / 0.45);
  }

  a.collection-card:hover .card-icon {
    transform: scale(1.08) rotate(-4deg);
  }

  /* ---------- Body ---------- */
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-heading {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .card-title {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01ch;
    line-height: 1.2;

    transition: color 200ms ease-out;
  }

  a.collection-card:hover .card-title {
    color: var(--accent);
  }

  .card-description {
    color: var(--clr-text-1);
    line-height: 1.55;
    font-size: 0.95rem;

    margin: 0;
  }

  /* ---------- Meta row ---------- */
  .card-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;

    width: fit-content;

    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05ch;
    text-transform: uppercase;

    color: var(--clr-text-2);

    margin: 0;
  }

  .card-meta--active {
    color: var(--accent);
  }

  .meta-dot {
    width: 0.5rem;
    height: 0.5rem;

    border-radius: 50%;
    background-color: var(--accent);
    box-shadow: 0 0 0 3px oklch(from var(--accent) l c h / 0.2);
  }

  .meta-dot--pending {
    background-color: transparent;
    border: 1px dashed var(--clr-text-2);
    box-shadow: none;
  }

  /* ---------- CTA row ---------- */
  .card-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;

    padding-top: 1rem;
    border-top: 1px solid var(--clr-surface-2);

    font-size: 0.875rem;
    font-weight: 500;

    color: var(--accent);
  }

  .cta-label--pending {
    color: var(--clr-text-2);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.02ch;
  }

  .cta-icon {
    font-size: 1rem;
    transition: transform 250ms ease-out;
  }

  a.collection-card:hover .cta-icon {
    transform: translateX(0.4rem);
  }

  /* ---------- Responsive ---------- */
  @media screen and (width < $width-desktop-1) {
    ul.collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (width < $width-mobile-2) {
    ul.collections-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .collections-intro {
      margin-top: 1.5rem;
      margin-bottom: 1rem;
    }

    .card-icon-area {
      aspect-ratio: 5 / 1.5;
    }

    .card-icon {
      font-size: 2.25rem;
    }

    .card-title {
      font-size: 1.2rem;
    }
  }
</style>
