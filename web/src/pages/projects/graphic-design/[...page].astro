---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { Page } from 'astro';
import Directory from '@layouts/Directory.astro';
import MasonryLayout from '@components/MasonryLayout.astro';
import MasonryCard from '@components/MasonryCard.astro';
import bg from '@assets/images/graphic-design-projects-hero.jpg';
import { Collection } from '@scripts/types';

export async function getStaticPaths({ paginate }: any) {
  const graphicDesignProjects = (await getCollection('graphicDesignProjects'))
    .filter((entry) => !entry.data.archived && entry.data.coverImage)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(graphicDesignProjects, { pageSize: 17 });
}

type Props = {
  page: Page<CollectionEntry<'graphicDesignProjects'>>;
};

const { page } = Astro.props;
---

<Directory
  page={page}
  pageTitle={`Graphic Design Projects | Austin Hagel`}
  collection={Collection.graphicDesignProjects}
  heroTitle='Graphic Design Projects'
  heroIcon='ri-artboard-line'
  route='/projects/graphic-design'
  image={bg}
  heroDescription='Explore my projects and work.'
  layout='masonry'
>
  <MasonryLayout slot='masonry'>
    {
      page.data.map((entry) => (
        <MasonryCard
          image={entry.data.coverImage!}
          imageAlt={entry.data.coverImage!.alt || entry.data.title}
          title={entry.data.title}
          category={entry.data.category}
          href={`/projects/graphic-design/${entry.id}`}
        />
      ))
    }
  </MasonryLayout>
</Directory>
