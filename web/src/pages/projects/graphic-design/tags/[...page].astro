---
import bg from '@assets/images/graphic-design-projects-hero.jpg';
import { Collection } from '@scripts/types';
import { getTags } from '@/scripts/fieldDataUtils';
import Taxonomy from '@/layouts/Taxonomy.astro';

export async function getStaticPaths({ paginate }: any) {
  const tags = await getTags(Collection.graphicDesignProjects);
  return paginate(tags, { pageSize: 12 });
}

const { page } = Astro.props;
---

<Taxonomy
  page={page}
  heroTitle='Tags'
  heroIcon='ri-price-tag-3-line'
  subtitle='Graphic Design Projects'
  baseRoute='/projects/graphic-design/tags'
  pageTitle='Graphic Design Projects - Tags | Austin Hagel'
  image={bg}
/>
