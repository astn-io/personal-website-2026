---
import bg from '@assets/images/3d-art-bg.jpg';
import { Collection } from '@scripts/types';
import { getCategories } from '@/scripts/fieldDataUtils';
import Taxonomy from '@/layouts/Taxonomy.astro';

export async function getStaticPaths({ paginate }: any) {
  const categories = await getCategories(Collection.threeDArtProjects);
  return paginate(categories, { pageSize: 10 });
}

const { page } = Astro.props;
---

<Taxonomy
  page={page}
  pageTitle='3D Art Projects - Categories | Austin Hagel'
  heroTitle='Categories'
  heroIcon='ri-apps-2-line'
  subtitle='3D Art Projects'
  baseRoute='/projects/3d-art/categories'
  image={bg}
/>
