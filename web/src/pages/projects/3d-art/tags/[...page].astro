---
import bg from '@assets/images/3d-art-bg.jpg';
import { Collection } from '@scripts/types';
import { getTags } from '@/scripts/fieldDataUtils';
import Taxonomy from '@/layouts/Taxonomy.astro';

export async function getStaticPaths({ paginate }: any) {
  const tags = await getTags(Collection.threeDArtProjects);
  return paginate(tags, { pageSize: 12 });
}

const { page } = Astro.props;
---

<Taxonomy
  page={page}
  heroTitle='Tags'
  heroIcon='ri-price-tag-3-line'
  subtitle='3D Art Projects'
  baseRoute='/projects/3d-art/tags'
  pageTitle='3D Art Projects - Tags | Austin Hagel'
  image={bg}
/>
