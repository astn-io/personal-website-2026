{
  "name": "astn",
  "type": "dark",
  "colors": {
    "editor.background": "var(--clr-base-0)",
    "editor.foreground": "var(--clr-text-0)"
  },
  "fg": "var(--clr-text-0)",
  "bg": "var(--clr-base-0)",
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "var(--clr-text-2)",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "var(--clr-green)"
      }
    },
    {
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": {
        "foreground": "var(--clr-aqua)"
      }
    },
    {
      "scope": ["constant.numeric", "constant.other.numeric"],
      "settings": {
        "foreground": "var(--clr-orange)"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "var(--clr-hotpink)"
      }
    },
    {
      "scope": ["constant", "constant.character", "constant.other"],
      "settings": {
        "foreground": "var(--clr-orange)"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "var(--clr-purple)"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "var(--clr-teal)"
      }
    },
    {
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "var(--clr-purple)"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "var(--clr-blue)"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "var(--clr-yellow)"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "var(--clr-text-0)"
      }
    },
    {
      "scope": ["variable.parameter", "variable.parameter.function"],
      "settings": {
        "foreground": "var(--clr-aqua)"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "var(--clr-hotpink)",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "var(--clr-text-1)"
      }
    },
    {
      "scope": ["entity.name.tag", "meta.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "var(--clr-red)"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "var(--clr-yellow)"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "support.type.property-name.css",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "var(--clr-blue)"
      }
    },
    {
      "scope": ["support.constant", "support.constant.property-value"],
      "settings": {
        "foreground": "var(--clr-orange)"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading.setext"],
      "settings": {
        "foreground": "var(--clr-purple)",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "var(--clr-orange)",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "var(--clr-yellow)",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "var(--clr-green)"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "var(--clr-teal)",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "var(--clr-text-2)",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": {
        "foreground": "var(--clr-green)"
      }
    },
    {
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": {
        "foreground": "var(--clr-red)"
      }
    },
    {
      "scope": ["markup.changed", "markup.changed.diff"],
      "settings": {
        "foreground": "var(--clr-yellow)"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "var(--clr-error)"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "var(--clr-pink)"
      }
    }
  ]
}
