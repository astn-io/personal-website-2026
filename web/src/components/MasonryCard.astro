---
import { Picture } from 'astro:assets';
import Badge from './Badge.astro';

type RemoteImage = {
  url: string;
  width: number;
  height: number;
  alt?: string;
};

interface Props {
  image: ImageMetadata | RemoteImage;
  imageAlt: string;
  title: string;
  category?: string;
  href?: string;
}

const { image, imageAlt, title, category, href } = Astro.props;

const isRemote = 'url' in image;

const MasonryCardElement = href ? 'a' : 'article';
---

<MasonryCardElement class='masonry-card' data-scroll-animate href={href}>
  <div class='image-wrapper'>
    {
      isRemote ? (
        <Picture
          src={image.url}
          width={image.width}
          height={image.height}
          alt={imageAlt}
          widths={[300, 500, 700, 900]}
          sizes='(max-width: 600px) 100vw, 400px'
          formats={['avif', 'webp']}
          fallbackFormat='webp'
          loading='lazy'
          decoding='async'
        />
      ) : (
        <Picture
          src={image}
          width={image.width}
          height={image.height}
          alt={imageAlt}
          widths={[300, 500, 700, 900]}
          sizes='(max-width: 600px) 100vw, 400px'
          formats={['avif', 'webp']}
          fallbackFormat='webp'
          loading='lazy'
          decoding='async'
        />
      )
    }
  </div>
  <div class='card-body'>
    {category && <Badge>{category}</Badge>}
    <h3 class='card-title'>{title}</h3>
  </div>
</MasonryCardElement>

<style lang='scss'>
  .masonry-card {
    display: block;
    width: 100%;
    margin: 0 0 var(--masonry-gap, 1.25rem);
    break-inside: avoid;

    color: inherit;
    text-decoration: none;

    border-radius: 12pt;

    transition: box-shadow 200ms ease-out;
  }

  .image-wrapper {
    width: 100%;
    overflow: hidden;
    background: var(--clr-overlay-1);
    border-radius: 12pt;
  }

  .image-wrapper :global(img) {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 400ms ease-out;
  }

  a.masonry-card:hover .image-wrapper :global(img) {
    transform: scale(1.03);
  }

  .card-body {
    padding-top: 0.75rem;
    padding-bottom: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--clr-text-0);
  }

  @media (prefers-reduced-motion: no-preference) {
    .masonry-card[data-scroll-animate] {
      opacity: 0;
    }

    .masonry-card[data-scroll-animate].visible {
      animation: masonry-fade-up 500ms ease-out forwards;
    }

    @keyframes masonry-fade-up {
      from {
        opacity: 0;
        transform: translateY(1.5rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
