---
import Button from '@components/Button.svelte';
import FeaturedLinks from '@components/FeaturedLinks.svelte';
import StyledHr from '@components/StyledHr.astro';
import ParticleBackground from '@components/ParticleBackground.astro';
import VideoBackground from '@components/VideoBackground.astro';

type CallToAction = {
  label: string;
  url?: string;
};

type Props = {
  title?: string;
  titleAccent?: string;
  subtitle?: string;
  summary?: string;
  primaryCta?: CallToAction;
  secondaryCta?: CallToAction;
  enableFeaturedLinks?: boolean;
  clipPath?: boolean;
  variant?: 'primary' | 'alternate';
};

const {
  title,
  titleAccent,
  subtitle,
  summary,
  primaryCta,
  secondaryCta,
  enableFeaturedLinks = true,
  clipPath = false,
  variant = 'primary',
} = Astro.props;
---

<section class='hero full-width' id='hero' data-clip-path={clipPath}>
  <VideoBackground clipPath={clipPath} />
  <ParticleBackground clipPath={clipPath} />
  <div class='hero-content'>
    {
      variant === 'primary' && (
        <>
          <div class='hero-title-container'>
            <h1 class='title-l hero-title hero-primary'>
              {title}
              {titleAccent && (
                <>
                  {' '}
                  <span class='text-accent'>{titleAccent}</span>
                </>
              )}
            </h1>
            <StyledHr />
            <h2 class='heading-4 hero-subtitle hero-primary'>{subtitle}</h2>
          </div>
        </>
      )
    }
    {
      variant === 'alternate' && (
        <>
          <h1 class='title-l hero-title hero-alternate'>{title}</h1>
          <h2 class='heading-4 hero-subtitle hero-alternate'>{subtitle}</h2>
          <StyledHr />
        </>
      )
    }
    {summary && <p class='hero-summary'>{summary}</p>}
    {
      enableFeaturedLinks && (
        <div class='social-links-wrapper'>
          <FeaturedLinks />
        </div>
      )
    }
    <div class='cta-buttons'>
      {
        primaryCta && (
          <Button link={primaryCta.url} variant='primary'>
            {primaryCta.label}
          </Button>
        )
      }
      {
        secondaryCta && (
          <Button link={secondaryCta.url} variant='secondary'>
            {secondaryCta!.label}
          </Button>
        )
      }
    </div>
  </div>
</section>

<style lang='scss'>
  @use '../../styles/variables.scss' as *;

  :global(:root[data-color-scheme='dark']) .hero-subtitle {
    // --subtitle-clr-text: oklch(from var(--clr-primary) calc(l + 0.1) c h);
    --subtitle-clr-text: var(--clr-text-0);
  }

  :global(:root[data-color-scheme='light']) .hero-subtitle {
    // --subtitle-clr-text: var(--clr-primary);
    --subtitle-clr-text: var(--clr-text-0);
  }

  section.hero {
    display: flex;
    flex-direction: column;
    justify-content: center;

    min-height: calc(100vh + var(--appbar-height));

    margin-top: calc(var(--appbar-height) * -1);

    overflow: hidden;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 0.6rem;

    margin-inline: auto;
    max-width: var(--max-width);
    width: 100%;

    padding-inline: 1rem;
  }

  section.hero[data-clip-path='false'] {
    padding-bottom: 10rem;
  }

  section.hero[data-clip-path='true'] {
    padding-bottom: 20rem;
  }

  p.hero-summary {
    margin-top: 0.5rem;
    margin-bottom: 0;
    color: var(--clr-text-1);

    font-size: 1.25rem;
  }

  .hero-title-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    min-width: fit-content;
  }

  .hero-title {
    margin-top: 0;
    margin-bottom: 1rem;

    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.075ch;
  }

  .text-accent {
    color: var(--clr-primary);
  }

  .hero-subtitle {
    margin-block: 0;

    font-size: 1.5rem;
    font-weight: 500;
    color: var(--subtitle-clr-text);
    // text-transform: uppercase;
    letter-spacing: 0.05ch;
  }

  .social-links-wrapper {
    justify-self: start;
    margin-block: 1rem;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;

    margin-top: 1rem;
  }

  /* --- Alternate Style --- */
  .hero-title.hero-alternate {
    text-transform: uppercase;
    font-weight: 200;
    letter-spacing: 0.4ch;
    transform: scaleY(95%);
  }

  .hero-subtitle.hero-alternate {
    margin-top: -1.75rem;
    margin-bottom: 0.75rem;

    color: var(--clr-text-2);
    text-transform: capitalize;
    letter-spacing: 0.05ch;
    font-weight: 400;
    font-size: 2rem;
  }

  @media screen and (width < $width-mobile-1) {
    .hero-title {
      font-size: 3.75rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    p {
      font-size: 1rem;
    }
  }
</style>
