---
import { getCollection } from 'astro:content';
import ContactButton from '@components/ContactButton.svelte';
import ThemeSelect from '@components/ThemeSelect.svelte';

const internalLinks = await getCollection('internalLinks');
const externalLinks = await getCollection('externalLinks');

const currentYear = new Date().getFullYear();

const allowedGroups = ['Development', 'Social'];

const filteredLinkGroups = externalLinks
  .filter((group) => allowedGroups.includes(group.data.label))
  .map((group) => ({
    ...group.data,
    links: group.data.links.filter((link) => link.enabled),
  }))
  .filter((group) => group.links.length > 0);
---

<footer class='content-grid'>
  <div class='footer-body'>
    <div class='footer-brand'>
      <a href='/' class='footer-brand-name'>Austin Hagel</a>
      <p class='footer-brand-tagline'>Developer & Designer</p>
      <p class='footer-brand-description'>
        A web development specialist with a knack for design. Building things
        for the open web.
      </p>
    </div>

    <div class='links-container'>
      <nav class='footer-nav' aria-label='Footer navigation'>
        <p class='footer-group-label'>
          <span class='ri-map-pin-line' aria-hidden='true'></span>
          Pages
        </p>
        <hr />
        <ul>
          {
            internalLinks.map((link) => (
              <li>
                <a href={link.data.url}>
                  <span class={link.data.icon} aria-hidden='true' />
                  {link.data.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {
        filteredLinkGroups.map((group) => (
          <div class='footer-link-group'>
            <p class='footer-group-label'>
              <span class={group.icon} aria-hidden='true' />
              {group.label}
            </p>
            <hr />
            <ul>
              {group.links.map((link) => (
                <li>
                  <a href={link.url} target='_blank' rel='noopener noreferrer'>
                    <span class={link.icon} aria-hidden='true' />
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class='footer-contact'>
      <p class='footer-group-label'>
        <span class='ri-mail-line' aria-hidden='true'></span>
        Contact
      </p>
      <hr />
      <a href='mailto:hello@astn.io' class='contact-email'>
        <!-- <span class='ri-mail-send-line' aria-hidden='true'></span> -->
        <span> hello@astn.io </span>
      </a>
      <p class='footer-contact-twinfire'>
        Need work done? I build through
        <a href='https://twinfire.io' target='_blank' rel='noopener noreferrer'
          >twinfire.io</a
        >
      </p>
      <ContactButton client:load icon='ri-chat-1-line' />
    </div>
  </div>

  <div class='footer-bottom'>
    <p>© {currentYear} Austin Hagel</p>
    <ThemeSelect client:load />
  </div>
</footer>

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  footer {
    margin-top: 12rem;
    background-color: var(--clr-surface-0);
    border-top: 1px solid var(--clr-surface-2);
    width: 100%;
    position: relative;

    &::before {
      content: '';
      position: absolute;
      inset-inline: 0;
      top: -1px;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent 0%,
        oklch(from var(--clr-primary) l c h / 0.5) 35%,
        oklch(from var(--clr-secondary) l c h / 0.4) 65%,
        transparent 100%
      );
    }
  }

  hr {
    margin-block: 0.15rem;
  }

  /* ── Body row ───────────────────────────────────────────── */

  .footer-body {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
    padding-block: 3.5rem 3rem;
  }

  /* ── Brand ─────────────────────────────────────────────── */

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex-shrink: 0;
    width: 220px;
  }

  .footer-brand-name {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.03rem;
    color: var(--clr-text-0);
    text-decoration: none;
    width: fit-content;
    transition: color 150ms ease-out;

    &:hover {
      color: var(--clr-primary);
    }
  }

  .footer-brand-tagline {
    margin: 0 0 0.5rem;
    font-size: 0.725rem;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: 0.12ch;
    text-transform: uppercase;
  }

  .footer-brand-description {
    margin: 0;
    font-size: 0.8rem;
    color: var(--clr-text-2);
    line-height: 1.7;
  }

  /* ── Nav & Link groups ──────────────────────────────────── */

  .links-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 3.5rem;
    flex: 1;
    padding-left: 3.5rem;
  }

  .footer-nav,
  .footer-link-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* ── Section labels ─────────────────────────────────────── */

  .footer-group-label {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;

    font-size: 0.675rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12ch;
    color: var(--clr-text-2);

    span {
      font-size: 0.8rem;
    }
  }

  /* ── Links ──────────────────────────────────────────────── */

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  li a {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    color: var(--clr-text-1);
    text-decoration: none;
    transition: color 150ms ease-out;

    span {
      font-size: 0.95rem;
      opacity: 0.6;
      transition: opacity 150ms ease-out;
    }

    &:hover {
      color: var(--clr-primary);

      span {
        opacity: 1;
      }
    }
  }

  /* ── Contact column ─────────────────────────────────────── */

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex-shrink: 0;
    padding-left: 3.5rem;
  }

  .contact-email {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    color: var(--clr-text-1);
    text-decoration: none;
    transition: color 150ms ease-out;

    span {
      font-size: 0.95rem;
      opacity: 0.6;
      transition: opacity 150ms ease-out;
    }

    &:hover {
      color: var(--clr-primary);

      span {
        opacity: 1;
      }
    }
  }

  .footer-contact-twinfire {
    margin: 0.4rem 0 0;
    font-size: 0.775rem;
    color: var(--clr-text-2);
    line-height: 1.6;

    margin-bottom: 1rem;

    a {
      color: var(--clr-primary);
      text-decoration: none;
      transition: color 150ms ease-out;

      &:hover {
        color: oklch(from var(--clr-primary) calc(l + 0.1) c h);
      }
    }
  }

  /* ── Bottom bar ─────────────────────────────────────────── */

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 4rem;
    padding-bottom: 2rem;

    p {
      margin: 0;
      font-size: 0.75rem;
      color: var(--clr-text-2);
      letter-spacing: 0.02rem;
    }

    .footer-bottom-credit {
      a {
        color: var(--clr-text-2);
        text-decoration: none;
        transition: color 150ms ease-out;

        &:hover {
          color: var(--clr-primary);
        }
      }
    }
  }

  /* ── Responsive ─────────────────────────────────────────── */

  @media screen and (width < $width-mobile-2) {
    .footer-body {
      flex-direction: column;
      gap: 2.5rem;
    }

    .footer-brand {
      width: auto;
    }

    .links-container {
      padding-left: 0;
      border-left: none;
      padding-top: 2.5rem;
      gap: 1.5rem 3rem;
    }

    .footer-contact {
      padding-left: 0;
      border-left: none;
      padding-top: 2.5rem;
      width: auto;
    }
  }

  @media screen and (width < $width-mobile-1) {
    footer {
      margin-top: 6rem;
    }

    .footer-body {
      padding-block: 2.5rem 2rem;
    }

    .links-container {
      gap: 1.5rem 2rem;
    }
  }
</style>
