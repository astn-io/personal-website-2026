---
import type { CollectionEntry } from 'astro:content';
import Card from '@components/Card.astro';
import slugify from '@scripts/slugify';
import Badge from '@components/Badge.astro';
import Tag from '@components/Tag.astro';

interface Props {
  project: CollectionEntry<'graphicDesignProjects'>;
  skew?: boolean;
  inList?: boolean;
}

const { project, skew = true, inList = false } = Astro.props;
---

<Card
  image={project.data.coverImage}
  imageAlt={project.data.coverAlt}
  inList={inList}
  skew={skew}
  link={`/projects/graphic-design/${project.id}`}
  linkLabel={project.data.title}
>
  <div class='card-meta-container' data-skew={skew}>
    {
      project.data.category && (
        <Badge
          icon='ri-apps-2-line'
          url={`/projects/graphic-design/categories/${slugify(project.data.category)}`}
        >
          {project.data.category}
        </Badge>
      )
    }
  </div>
  <h3 class='truncate card-title' data-skew={skew}>
    {project.data.title}
  </h3>
  <p class='card-description truncate-2' data-skew={skew}>
    {project.data.description}
  </p>
  <div class='card-footer'>
    {
      project.data.tags && (
        <ul class='project-tags-list'>
          {project.data.tags.map((tag) => (
            <li>
              <Tag
                label={tag}
                style='simple'
                url={`/projects/graphic-design/tags/${slugify(tag)}`}
              />
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Card>

<style lang='scss'>
  @use '../../styles/variables.scss' as *;

  .card-meta-container,
  .card-footer {
    position: relative;
    z-index: 2;
  }

  h3.card-title {
    color: var(--title-color);
    display: flex;
    align-items: center;
    justify-content: start;
    gap: 0.5ch;

    min-width: 0;

    font-size: 1.5rem;
    font-weight: 500;

    margin-left: -3rem;
  }

  h3.card-title[data-skew='false'] {
    margin-left: 0;
  }

  .card-meta-container {
    display: flex;
    align-items: center;
    gap: 0.6rem;

    height: fit-content;

    margin-left: -4rem;
  }

  .card-meta-container[data-skew='false'] {
    margin-left: 0;
  }

  p.card-description {
    color: var(--clr-text-1);
  }

  p.card-description[data-skew='true'] {
    margin-left: -1.5rem;
  }

  p.card-description[data-skew='false'] {
    margin-left: 0;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  ul.project-tags-list {
    display: flex;
    gap: 1rem;

    padding: 0;
    list-style-type: none;
  }

  @media screen and (width < $width-mobile-1) {
    .card-meta-container {
      margin-left: 0;
    }

    h3.card-title {
      margin-left: 0;
      margin-top: 0.5rem;
      font-size: 1.25rem;
    }

    p.card-description[data-skew] {
      margin-left: 0;
    }
  }
</style>
