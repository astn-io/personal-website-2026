---
import CardImage from '@components/CardImage.astro';

type RemoteImage = {
  url: string;
  width: number;
  height: number;
  alt?: string;
};

interface Props {
  image?: ImageMetadata | RemoteImage;
  imageAlt?: string;
  link?: string;
  linkLabel?: string;
  skew?: boolean;
  inList?: boolean;
}

const { image, imageAlt, link, linkLabel, skew = true, inList = false } = Astro.props;

const hasImage: boolean = !!image;
---

{
  inList ? (
    <li data-skew={skew} data-scroll-animate data-has-image={hasImage}>
      {link && <a href={link} class='card-link' aria-label={linkLabel}></a>}
      {image && imageAlt && (
        <CardImage skew={skew} image={image} imageAlt={imageAlt} />
      )}
      <div class='card-content'>
        <slot />
      </div>
    </li>
  ) : (
    <article data-skew={skew} data-scroll-animate data-has-image={hasImage}>
      {link && <a href={link} class='card-link' aria-label={linkLabel}></a>}
      {image && imageAlt && (
        <CardImage skew={skew} image={image} imageAlt={imageAlt} />
      )}
      <div class='card-content'>
        <slot />
      </div>
    </article>
  )
}

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  article,
  li {
    --skew: 20deg;
    --card-border-radius: 16pt;
    --card-height: 14rem;
    --skew-offset: calc(var(--card-height) * tan(var(--skew)));

    --img-grayscale: 40%;
    --img-opacity: 0.8;
    --img-border-radius: 0;
    --border-pos-current: var(--border-pos, 100% 0);
    --title-color: var(--clr-text-0);

    position: relative;

    display: grid;
    gap: 1rem;

    height: var(--card-height);
  }

  article[data-has-image='false'],
  li[data-has-image='false'] {
    display: flex;
  }

  article[data-skew='true'],
  li[data-skew='true'] {
    margin-inline: 1.75rem;
    --img-border-radius: var(--card-border-radius);
    --img-scale: 1.35;
    --img-scale-hover: 1.45;
  }

  article[data-skew='false'],
  li[data-skew='false'] {
    --card-border-radius: 6pt;
    --img-scale: 1;
    --img-scale-hover: 1.05;
  }

  article::after,
  li::after {
    content: '';
    position: absolute;
    top: 0;

    height: 100%;

    background-color: var(--clr-surface-0);

    border-radius: var(--card-border-radius);

    z-index: -1;

    transition-property: background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  article[data-skew='false']::after,
  li[data-skew='false']::after {
    width: 100%;
    left: 0;
  }

  article[data-skew='true']::after,
  li[data-skew='true']::after {
    transform: skew(var(--skew));
    width: 100%;
  }

  article:hover::after,
  li:hover::after {
    background-color: var(--clr-surface-1);
  }

  article:hover,
  li:hover {
    --img-grayscale: 0%;
    --img-opacity: 1;
    --border-pos-current: var(--border-pos-hover, 0% 0);
    --img-scale: var(--img-scale-hover);
    --title-color: var(--clr-primary);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  article[data-skew='true'] .card-link,
  li[data-skew='true'] .card-link {
    transform: skew(var(--skew));
  }

  article:nth-child(odd),
  li:nth-child(odd) {
    grid-template-columns: 2fr 3fr;
    grid-template-areas: 'image content';

    --border-direction: to right;
    --border-pos: 100% 0;
    --border-pos-hover: 0% 0;
  }

  article:nth-child(even),
  li:nth-child(even) {
    grid-template-columns: 3fr 2fr;
    grid-template-areas: 'content image';

    --border-direction: to left;
    --border-pos: 0% 0;
    --border-pos-hover: 100% 0;
  }

  .card-content {
    grid-area: content;

    display: grid;

    max-width: 100%;

    padding-block: 1rem;
  }

  article[data-skew='true']:nth-child(odd) > .card-content,
  li[data-skew='true']:nth-child(odd) > .card-content {
    padding-right: 1rem;
    margin-left: 2rem;
    padding-left: 1rem;
  }

  article[data-skew='true']:nth-child(even) > .card-content,
  li[data-skew='true']:nth-child(even) > .card-content {
    padding-left: 4rem;
    padding-right: 1rem;
  }

  article[data-skew='false']:nth-child(odd) > .card-content,
  li[data-skew='false']:nth-child(odd) > .card-content {
    padding-right: 1rem;
  }

  article[data-skew='false']:nth-child(even) > .card-content,
  li[data-skew='false']:nth-child(even) > .card-content {
    padding-left: 1rem;
  }

  /* --- Scroll animations --- */

  @media (prefers-reduced-motion: no-preference) {
    article[data-scroll-animate],
    li[data-scroll-animate] {
      opacity: 0;
    }

    article[data-scroll-animate]:nth-child(even),
    li[data-scroll-animate]:nth-child(even) {
      --slide-from: 4rem;
    }

    article[data-scroll-animate].visible,
    li[data-scroll-animate].visible {
      animation-name: slide-fade-in;
      animation-duration: 500ms;
      animation-timing-function: ease-out;
      animation-fill-mode: forwards;
    }

    @keyframes slide-fade-in {
      from {
        opacity: 0;
        transform: translateX(var(--slide-from, -4rem));
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  }

  @media screen and (width >= $width-mobile-1) {
    article[data-skew='false']:nth-child(odd),
    li[data-skew='false']:nth-child(odd) {
      --img-border-radius: var(--card-border-radius) 0 0
        var(--card-border-radius);
    }

    article[data-skew='false']:nth-child(even),
    li[data-skew='false']:nth-child(even) {
      --img-border-radius: 0 var(--card-border-radius) var(--card-border-radius)
        0;
    }
  }

  @media screen and (width < $width-mobile-1) {
    article,
    li {
      --skew: 0;
      --img-border-radius: 16pt;
    }

    article:nth-child(n),
    li:nth-child(n) {
      grid-template-columns: 1fr;
      grid-template-rows: 14rem auto;
      grid-template-areas:
        'image'
        'content';

      height: auto;

      margin-inline: 0;
    }

    article[data-skew]:nth-child(n) > .card-content,
    li[data-skew]:nth-child(n) > .card-content {
      padding-inline: 1rem;
      padding-top: 0;
      padding: 0;
      margin: 0;
    }

    article::after,
    li::after {
      background-color: transparent;
    }

    article:hover::after,
    li:hover::after {
      background-color: inherit;
    }
  }
</style>
