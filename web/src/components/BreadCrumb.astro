---
function formatPathSegment(segment: string) {
  let decoded = decodeURIComponent(segment);

  decoded = decoded.replace(/\+/g, ' ');

  decoded = decoded.replace(/[-_]/g, ' ');

  decoded = decoded
    .split(' ')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
    .join(' ');

  return decoded;
}

const currentPath = Astro.url.pathname;

function generateBreadcrumbs(path: string) {
  const segments = path.replace(/\/$/, '').split('/').filter(Boolean);

  return segments.map((segment, index) => {
    const url = '/' + segments.slice(0, index + 1).join('/');
    const label = formatPathSegment(segment);

    return {
      label,
      url,
    };
  });
}

const breadcrumbs = generateBreadcrumbs(currentPath);
---

<nav aria-label='Breadcrumb' class='breadcrumb content-grid'>
  <ol class='breadcrumb-list'>
    {
      breadcrumbs.length > 0 && (
        <li class='breadcrumb-item'>
          <a href='/'>
            <span class='ri-home-line' />
            <span class='visually-hidden'>Home</span>
          </a>
          {breadcrumbs.length > 0 && (
            <span class='separator ri-arrow-right-s-line' />
          )}
        </li>
      )
    }
    {
      breadcrumbs.length > 0 &&
        breadcrumbs.map((crumb, index) => (
          <li class='breadcrumb-item'>
            {index === breadcrumbs.length - 1 ? (
              <span class='current' aria-current='page'>
                {crumb.label}
              </span>
            ) : (
              <>
                <a href={crumb.url}>{crumb.label}</a>
                <span class='separator ri-arrow-right-s-line' />
              </>
            )}
          </li>
        ))
    }
  </ol>
</nav>

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  nav.breadcrumb {
    position: absolute;
    top: 5.25rem;

    width: 100%;

    z-index: $z-index-breadcrumb;
  }

  ol.breadcrumb-list {
    position: relative;

    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 0 0.125rem;

    list-style: none;

    padding-inline: 0.5rem;
    padding-block: 0.1rem;

    max-width: fit-content;
  }

  ol.breadcrumb-list::after {
    content: '';
    position: absolute;
    inset: 0;

    border-radius: 999px;
    background-color: oklch(from var(--clr-base-0) l c h / 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid oklch(from var(--clr-surface-2) l c h / 0.5);

    z-index: -1;
  }

  li.breadcrumb-item {
    display: flex;
    align-items: center;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    font-weight: 400;
    color: var(--clr-text-2);
  }

  li.breadcrumb-item a {
    color: var(--clr-text-2);
    text-decoration: none;
    transition: color 200ms ease;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
  }

  li.breadcrumb-item a:hover {
    color: var(--clr-primary);
  }

  .separator {
    color: oklch(from var(--clr-text-2) l c h / 0.5);
    font-size: 0.85rem;
    line-height: 1;
  }

  .current {
    color: var(--clr-text-1);
    font-weight: 500;
    padding: 0.125rem 0.25rem;
  }

  @media screen and (width < $width-mobile-2) {
    nav.breadcrumb {
      top: 4rem;
    }
  }
</style>
