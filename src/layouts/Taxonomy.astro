---
import type { Page } from 'astro';
import Base from '@layouts/Base.astro';
import DirectoryHero from '@components/DirectoryHero.astro';
import Paginator from '@components/Paginator.astro';
import slugify from '@scripts/slugify';

type Props = {
  page: Page;
  heroTitle: string;
  heroIcon?: string;
  baseRoute: string;
  pageTitle?: string;
  image?: ImageMetadata;
};

const { page, heroTitle, heroIcon, baseRoute, pageTitle, image } = Astro.props;
---

<Base title={pageTitle}>
  <DirectoryHero title={heroTitle} titleIcon={heroIcon} image={image} />

  <section class='taxonomy-container'>
    <p class='taxonomy-subtitle'>
      <span>{page.total} {heroTitle.toLowerCase()}</span>
    </p>

    <ul class='taxonomy-grid'>
      {
        page.data.map(
          (item: { name: string; count: number }, index: number) => (
            <li
              data-scroll-animate
              style={`--_delay: ${Math.min(index * 80, 600)}ms`}
            >
              <a
                href={`${baseRoute}/${slugify(item.name)}`}
                class='taxonomy-card'
              >
                <span class='card-count-bg' aria-hidden='true'>
                  {item.count}
                </span>
                <div class='card-body'>
                  <span class='card-name'>{item.name}</span>
                  <span class='card-post-count'>
                    {item.count} {item.count === 1 ? 'post' : 'posts'}
                  </span>
                </div>
                <div class='card-footer'>
                  <span class='card-cta'>Browse</span>
                  <span class='ri-arrow-right-line card-arrow' />
                </div>
              </a>
            </li>
          ),
        )
      }
    </ul>

    <div class='paginator-container'>
      <Paginator page={page} />
    </div>
  </section>

  <style>
    .taxonomy-container {
      min-height: calc(100svh - var(--appbar-height));
      display: flex;
      flex-direction: column;
    }

    .taxonomy-subtitle {
      margin-block: 2.5rem 0;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.2ch;
      color: var(--clr-text-1);
    }

    .taxonomy-grid {
      list-style: none;
      padding: 0;
      margin-block: 1.5rem 3rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
      gap: 1.25rem;
    }

    /* --- Scroll animations --- */

    li {
      opacity: 0;
      transform: translateY(1rem);
      transition:
        opacity 500ms ease-out var(--_delay, 0ms),
        transform 500ms ease-out var(--_delay, 0ms);
    }

    li.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* --- Card --- */

    .taxonomy-card {
      position: relative;
      overflow: hidden;

      display: flex;
      flex-direction: column;
      justify-content: space-between;

      min-height: 11rem;
      padding: 1.5rem;

      border-radius: 12pt;
      background-color: var(--clr-surface-0);
      border-left: 3px solid var(--clr-primary);
      outline: 1px solid var(--clr-surface-1);

      text-decoration: none;
      color: var(--clr-text-0);

      transition-property:
        background-color, outline-color, border-color, transform;
      transition-duration: 200ms;
      transition-timing-function: ease-out;
    }

    .taxonomy-card:hover {
      background-color: var(--clr-surface-1);
      outline-color: var(--clr-surface-2);
      transform: translateY(-3px);
    }

    /* --- Decorative background count --- */

    .card-count-bg {
      position: absolute;
      top: -0.3rem;
      right: 0.75rem;

      font-size: 7rem;
      font-weight: 800;
      line-height: 1;
      color: var(--clr-surface-1);

      user-select: none;
      pointer-events: none;

      transition: color 200ms ease-out;
    }

    .taxonomy-card:hover .card-count-bg {
      color: var(--clr-surface-2);
    }

    /* --- Card body --- */

    .card-body {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .card-name {
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.3;
    }

    .card-post-count {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--clr-text-1);
    }

    /* --- Card footer --- */

    .card-footer {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.4rem;

      margin-top: 1rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--clr-surface-1);

      transition: border-color 200ms ease-out;
    }

    .taxonomy-card:hover .card-footer {
      border-color: var(--clr-surface-2);
    }

    .card-cta {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--clr-text-1);

      transition: color 200ms ease-out;
    }

    .taxonomy-card:hover .card-cta {
      color: var(--clr-primary);
    }

    .card-arrow {
      font-size: 1rem;
      color: var(--clr-text-1);

      transform: translateX(0);
      opacity: 0;

      transition-property: opacity, transform, color;
      transition-duration: 200ms;
      transition-timing-function: ease-out;
    }

    .taxonomy-card:hover .card-arrow {
      opacity: 1;
      transform: translateX(0.25rem);
      color: var(--clr-primary);
    }

    .paginator-container {
      margin-top: auto;
    }
  </style>
</Base>
