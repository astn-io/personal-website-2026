---
import type { Page } from 'astro';
import Base from '@layouts/Base.astro';
import Paginator from '@components/Paginator.astro';
import BlogCard from '@components/cards/BlogCard.astro';
import FrontendProjectCard from '@components/cards/FrontendProjectCard.astro';
import DirectoryHero from '@/components/DirectoryHero.astro';

type Props = {
  page: Page;
  collection: 'blog' | 'frontendProjects';
  heroTitle: string;
  title?: string;
};

const { page, collection, heroTitle, title } = Astro.props;
---

<Base title={title}>
  <DirectoryHero title={heroTitle} />
  <section class='page-content'>
    <ul>
      {
        collection === 'blog' &&
          page.data.map((post) => <BlogCard post={post} inList={true} />)
      }
      {
        collection === 'frontendProjects' &&
          page.data.map((project) => (
            <FrontendProjectCard project={project} inList={true} />
          ))
      }
    </ul>
    <div class='paginator-container'>
      <Paginator page={page} />
    </div>
  </section>

  <style>
    section {
      min-height: calc(100svh - var(--appbar-height));
      display: flex;
      flex-direction: column;
    }

    ul {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;

      list-style-type: none;
      padding: 0;
    }

    .paginator-container {
      margin-top: auto;
    }
  </style>
</Base>
