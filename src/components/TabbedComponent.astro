---
type Tab = {
  label: string;
  icon?: string;
};

type Props = {
  tabs: Tab[];
};

const { tabs } = Astro.props;
---

<div class='tabbed-component-container'>
  <div class='tab-btn-group'>
    {
      tabs.map((tab, i) => (
        <button
          class='tab-btn'
          data-tab-id={i}
          data-active={i === 0 ? 'true' : 'false'}
        >
          <span class={`${tab.icon} tab-btn-icon`} />
          <span>{tab.label}</span>
        </button>
      ))
    }
    <span class='tab-indicator'></span>
  </div>
  <div class='tab-content'>
    <slot />
  </div>
</div>

<style>
  .tabbed-component-container {
    display: grid;
  }

  .tab-btn-group {
    position: relative;
    display: flex;

    background-color: transparent;
  }

  .tab-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5ch;

    padding-inline: 1.5rem;
    padding-block: 0.6rem;
    margin: 0;

    border: none;

    border-radius: 4pt 4pt 0 0;

    background-color: transparent;

    color: var(--clr-subtext-0);

    cursor: pointer;

    transition-property: background-color, color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .tab-btn-icon {
    position: relative;
    top: 0.035rem;
  }

  .tab-btn:hover {
    background-color: var(--clr-surface-0);
    color: var(--clr-text);
  }

  .tab-btn[data-active='true'] {
    background-color: var(--clr-surface-0);
    color: var(--clr-text);
  }

  .tab-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;

    background-color: var(--clr-primary);

    transition:
      transform 200ms ease-out,
      width 200ms ease-out;
  }

  .tab-content {
    display: grid;
  }

  .tab-content > :global([data-tab-id]) {
    grid-row: 1;
    grid-column: 1;
    align-self: start;

    background-color: var(--clr-surface-0);

    border-radius: 0 0 10pt 10pt;

    overflow: hidden;

    padding-top: 1rem;

    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease-out;
  }

  .tab-content > :global([data-active='true']) {
    opacity: 1;
    pointer-events: auto;
  }

  @keyframes slide-in-right {
    from {
      opacity: 0;
      transform: translateX(25%);
    }
  }

  @keyframes slide-in-left {
    from {
      opacity: 0;
      transform: translateX(-25%);
    }
  }

  .tab-content > :global([data-active='true'][data-direction='right']) {
    animation: slide-in-right 250ms ease-out;
  }

  .tab-content > :global([data-active='true'][data-direction='left']) {
    animation: slide-in-left 250ms ease-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .tab-indicator {
      transition: none;
    }

    .tab-content > :global([data-tab-id]) {
      transition: none;
    }

    .tab-content > :global([data-active='true'][data-direction='right']),
    .tab-content > :global([data-active='true'][data-direction='left']) {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document
      .querySelectorAll<HTMLDivElement>('.tabbed-component-container')
      .forEach((container) => {
        const buttons =
          container.querySelectorAll<HTMLButtonElement>('.tab-btn');
        const sections =
          container.querySelectorAll<HTMLElement>('.tab-section');
        const indicator =
          container.querySelector<HTMLSpanElement>('.tab-indicator');
        let activeIndex = 0;

        function positionIndicator() {
          const activeBtn = container.querySelector<HTMLButtonElement>(
            '.tab-btn[data-active="true"]',
          );
          if (!activeBtn || !indicator) return;

          const groupRect = indicator.parentElement!.getBoundingClientRect();
          const btnRect = activeBtn.getBoundingClientRect();

          indicator.style.width = `${btnRect.width}px`;
          indicator.style.transform = `translateX(${btnRect.left - groupRect.left}px)`;
        }

        positionIndicator();

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const newIndex = Number(btn.dataset.tabId);
            if (newIndex === activeIndex) return;

            const direction = newIndex > activeIndex ? 'right' : 'left';

            buttons.forEach((b) => (b.dataset.active = 'false'));
            sections.forEach((s) => {
              s.dataset.active = 'false';
              delete s.dataset.direction;
            });

            btn.dataset.active = 'true';

            const newSection = container.querySelector<HTMLElement>(
              `.tab-section[data-tab-id="${newIndex}"]`,
            );

            if (newSection) {
              newSection.dataset.active = 'true';

              requestAnimationFrame(() => {
                newSection.dataset.direction = direction;
              });
            }

            activeIndex = newIndex;
            positionIndicator();
          });
        });

        window.addEventListener('resize', positionIndicator);
      });
  });
</script>
