---
import { Picture } from 'astro:assets';

type Props = {
  images: { src: ImageMetadata; alt: string }[];
};
const { images } = Astro.props;
---

<div class='carousel-container'>
  <ul class='carousel-images-list' id='carousel'>
    {
      images.map((img) => (
        <li class='carousel-image-list-item'>
          <Picture
            src={img.src}
            alt={img.alt}
            class='carousel-img'
            loading='eager'
          />
        </li>
      ))
    }
  </ul>
  <button
    class='carousel-nav-btn carousel-nav-btn-prev'
    title='View previous image'
  >
    <span class='ri-arrow-left-s-line'></span>
  </button>
  <button
    class='carousel-nav-btn carousel-nav-btn-next'
    title='View next image'
  >
    <span class='ri-arrow-right-s-line'></span>
  </button>
</div>

<style>
  .carousel-container {
    position: relative;

    height: 100%;
    width: 100%;

    background-color: var(--clr-surface-0);
  }

  ul.carousel-images-list {
    display: flex;
    align-items: center;

    padding: 0;
    margin: 0;

    list-style-type: none;

    transform: translate3d(calc(var(--index, 0) * -100%), 0, 0);
    transition: transform 300ms ease;
    will-change: transform;
    backface-visibility: hidden;
  }

  li.carousel-image-list-item {
    flex: 0 0 100%;
    height: min(40rem, 70vh);
  }

  li.carousel-image-list-item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .carousel-img {
    object-fit: contain;
    width: 100%;
    height: 100%;
  }

  button.carousel-nav-btn {
    --size: 3.5rem;

    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    display: flex;
    align-items: center;
    justify-content: center;

    height: var(--size);
    width: var(--size);

    cursor: pointer;

    border: none;
    border-radius: 50%;

    outline: 0.1rem solid var(--clr-surface-2);

    color: var(--clr-text-2);
    font-size: 2.25rem;

    background-color: transparent;
    backdrop-filter: blur(12px);

    transition-property: color, background-color, outline-color, opacity;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-btn:hover {
    color: var(--clr-text-0);
  }

  button.carousel-nav-btn::after {
    content: '';
    position: absolute;
    inset: 0;

    background-color: var(--clr-base-0);

    opacity: 0.4;

    z-index: -1;

    border-radius: 50%;

    transition-property: background-color, outline-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-btn:hover::after {
    background-color: var(--clr-surface-1);
  }

  button.carousel-nav-btn-prev {
    left: 1rem;
  }

  button.carousel-nav-btn-prev > span {
    position: relative;
    left: -0.08rem;
  }

  button.carousel-nav-btn-next {
    right: 1rem;
  }

  button.carousel-nav-btn-next > span {
    position: relative;
    right: -0.08rem;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const carousel = document.getElementById('carousel');
    if (!carousel) return;

    const container = carousel.parentElement;
    const prevBtn = container?.querySelector<HTMLButtonElement>(
      '.carousel-nav-btn-prev',
    );
    const nextBtn = container?.querySelector<HTMLButtonElement>(
      '.carousel-nav-btn-next',
    );
    const items = Array.from(carousel.children) as HTMLElement[];
    const count = items.length;
    if (count <= 1) return;

    for (let i = count - 1; i >= 0; i--) {
      const clone = items[i].cloneNode(true) as HTMLElement;
      clone.setAttribute('aria-hidden', 'true');
      carousel.insertBefore(clone, carousel.firstChild);
    }

    carousel.querySelectorAll('img').forEach((img) => {
      img.decode?.().catch(() => {});
    });

    const total = count * 2;
    let index = count;
    const apply = (animate: boolean) => {
      if (!animate) {
        carousel.style.transition = 'none';
        void carousel.offsetWidth;
      }
      carousel.style.setProperty('--index', String(index));
      if (!animate) {
        void carousel.offsetWidth;
        carousel.style.transition = '';
      }
    };
    apply(false);

    carousel.addEventListener('transitionend', (e) => {
      if (e.propertyName !== 'transform') return;
      if (index === 0) {
        index = count;
        apply(false);
      }
    });

    const nav = (direction: 1 | -1) => {
      if (direction === 1 && index === total - 1) {
        index = count - 1;
        apply(false);
      } else if (direction === -1 && index === 0) {
        index = count;
        apply(false);
      }
      index += direction;
      apply(true);
    };

    prevBtn?.addEventListener('click', () => nav(-1));
    nextBtn?.addEventListener('click', () => nav(1));
  });
</script>
