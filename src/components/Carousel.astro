---
import { Picture } from 'astro:assets';

type Props = {
  images: { src: ImageMetadata; alt: string }[];
};
const { images } = Astro.props;
---

<div class='carousel-container'>
  <ul class='carousel-images-list' id='carousel'>
    {
      images.map((img) => (
        <li class='carousel-image-list-item'>
          <Picture
            src={img.src}
            alt={img.alt}
            class='carousel-img'
            loading='eager'
          />
        </li>
      ))
    }
  </ul>

  <button
    class='carousel-nav-btn carousel-nav-btn-prev'
    title='View previous image'
  >
    <span class='ri-arrow-left-s-line'></span>
  </button>
  <button
    class='carousel-nav-btn carousel-nav-btn-next'
    title='View next image'
  >
    <span class='ri-arrow-right-s-line'></span>
  </button>

  <div class='carousel-caption' aria-live='polite'></div>

  <nav class='carousel-nav' aria-label='Carousel pagination'>
    <ul class='carousel-nav-list'>
      {
        images.map((_, i) => (
          <li>
            <button
              type='button'
              class='carousel-nav-indicator'
              data-index={i}
              aria-label={`Go to image ${i + 1}`}
            />
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  .carousel-container {
    position: relative;

    height: 100%;
    width: 100%;

    background-color: var(--clr-surface-0);
  }

  ul.carousel-images-list {
    display: flex;
    align-items: center;

    padding: 0;
    margin: 0;

    list-style-type: none;

    transform: translate3d(calc(var(--index, 0) * -100%), 0, 0);
    transition: transform 300ms ease;
    will-change: transform;
    backface-visibility: hidden;
  }

  li.carousel-image-list-item {
    flex: 0 0 100%;
    height: min(40rem, 70vh);
  }

  li.carousel-image-list-item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .carousel-img {
    object-fit: contain;
    width: 100%;
    height: 100%;

    border-radius: 8pt;
  }

  nav.carousel-nav {
    display: flex;
    justify-content: center;

    padding-block: 1rem;
  }

  ul.carousel-nav-list {
    position: relative;

    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;

    padding: 0.5rem 0.75rem;
    margin: 0;

    list-style-type: none;

    background-color: oklch(from var(--clr-surface-1) l c h);

    border-radius: 9999px;
  }

  button.carousel-nav-indicator {
    --width: 1.75rem;
    --height: 0.5rem;

    position: relative;

    display: block;

    background-color: transparent;

    padding-inline: 1rem;
    padding-block: 0.75rem;

    cursor: pointer;

    border: none;
    border-radius: 50%;

    transition-property: background-color, transform, width, height;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-indicator::after {
    content: '';
    position: absolute;

    top: 50%;
    left: 50%;

    transform: translateX(-50%) translateY(-50%);

    width: var(--width);
    height: var(--height);

    border-radius: var(--height);

    background-color: var(--clr-overlay-2);

    transition-property: background-color, transform, width, height;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-indicator:hover::after {
    --size: 1.75rem;

    background-color: var(--clr-text-1);
  }

  button.carousel-nav-indicator[aria-current='true']::after {
    --height: 1.5rem;
    --width: 1.5rem;
    background-color: var(--clr-primary);
  }

  button.carousel-nav-indicator::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;

    height: 2.5rem;
    width: 2.5rem;

    border-radius: 50%;

    background-image: none;
    opacity: 0;

    transition-property: opacity;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-indicator[aria-current='true']::before {
    opacity: 1;

    background-image: radial-gradient(
      circle,
      oklch(from var(--clr-primary) l c h / 0.8) 0%,
      oklch(from var(--clr-primary) l c h / 0.3) 50%,
      transparent 70%
    );
  }

  button.carousel-nav-btn {
    --size: 3.5rem;

    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    display: flex;
    align-items: center;
    justify-content: center;

    height: var(--size);
    width: var(--size);

    cursor: pointer;

    border: none;
    border-radius: 50%;

    outline: 0.1rem solid transparent;

    color: var(--clr-text-2);
    font-size: 2.25rem;

    background-color: transparent;
    backdrop-filter: blur(12px);

    transition-property: color, background-color, outline-color, opacity;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-btn:hover {
    color: var(--clr-text-0);
  }

  button.carousel-nav-btn::after {
    content: '';
    position: absolute;
    inset: 0;

    background-color: var(--clr-base-0);

    opacity: 0.4;

    z-index: -1;

    border-radius: 50%;

    transition-property: background-color, outline-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  button.carousel-nav-btn:hover::after {
    background-color: var(--clr-surface-1);
  }

  button.carousel-nav-btn-prev {
    left: 1rem;
  }

  button.carousel-nav-btn-prev > span {
    position: relative;
    left: -0.08rem;
  }

  button.carousel-nav-btn-next {
    right: 1rem;
  }

  button.carousel-nav-btn-next > span {
    position: relative;
    right: -0.08rem;
  }

  .carousel-caption {
    position: absolute;
    bottom: 5.5rem;
    left: 50%;
    transform: translateX(-50%);

    max-width: calc(100% - 10rem);

    padding: 0.35rem 0.9rem;

    font-size: 0.8rem;
    color: var(--clr-text-1);
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;

    background-color: oklch(from var(--clr-surface-0) l c h / 0.65);
    backdrop-filter: blur(12px);

    border-radius: 9999px;

    pointer-events: none;

    &:empty {
      display: none;
    }
  }

  @media screen and (width < $width-mobile-1) {
    ul.carousel-nav-list {
      border-radius: 4pt;
      margin-inline: 1rem;
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const carousel = document.getElementById('carousel');
    if (!carousel) return;

    const container = carousel.parentElement;
    const prevBtn = container?.querySelector<HTMLButtonElement>(
      '.carousel-nav-btn-prev',
    );
    const nextBtn = container?.querySelector<HTMLButtonElement>(
      '.carousel-nav-btn-next',
    );
    const items = Array.from(carousel.children) as HTMLElement[];
    const count = items.length;
    if (count <= 1) return;

    const indicators = Array.from(
      container?.querySelectorAll<HTMLButtonElement>(
        '.carousel-nav-indicator',
      ) ?? [],
    );

    for (let i = count - 1; i >= 0; i--) {
      const clone = items[i].cloneNode(true) as HTMLElement;
      clone.setAttribute('aria-hidden', 'true');
      carousel.insertBefore(clone, carousel.firstChild);
    }

    carousel.querySelectorAll('img').forEach((img) => {
      img.decode?.().catch(() => {});
    });

    const total = count * 2;
    let index = count;
    const apply = (animate: boolean) => {
      if (!animate) {
        carousel.style.transition = 'none';
        void carousel.offsetWidth;
      }
      carousel.style.setProperty('--index', String(index));
      if (!animate) {
        void carousel.offsetWidth;
        carousel.style.transition = '';
      }
    };

    const caption = container?.querySelector<HTMLElement>('.carousel-caption');

    const updateIndicators = () => {
      const active = ((index % count) + count) % count;
      indicators.forEach((btn, i) => {
        if (i === active) {
          btn.setAttribute('aria-current', 'true');
        } else {
          btn.removeAttribute('aria-current');
        }
      });
      if (caption) {
        caption.textContent = items[active].querySelector('img')?.alt ?? '';
      }
    };

    apply(false);
    updateIndicators();

    carousel.addEventListener('transitionend', (e) => {
      if (e.propertyName !== 'transform') return;
      if (index === 0) {
        index = count;
        apply(false);
      }
    });

    const nav = (direction: 1 | -1) => {
      if (direction === 1 && index === total - 1) {
        index = count - 1;
        apply(false);
      } else if (direction === -1 && index === 0) {
        index = count;
        apply(false);
      }
      index += direction;
      apply(true);
      updateIndicators();
    };

    const goTo = (target: number) => {
      const active = ((index % count) + count) % count;
      if (target === active) return;
      if (index < count) {
        index += count;
        apply(false);
      }
      index = count + target;
      apply(true);
      updateIndicators();
    };

    prevBtn?.addEventListener('click', () => nav(-1));
    nextBtn?.addEventListener('click', () => nav(1));
    indicators.forEach((btn, i) => {
      btn.addEventListener('click', () => goTo(i));
    });
  });
</script>
