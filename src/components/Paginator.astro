---
const { page } = Astro.props;

const hasPages = page.url.next !== undefined || page.url.prev !== undefined;
const baseUrl = page.url.first ?? page.url.current;

function getPageItems(currentPage: number, lastPage: number): number[] {
  const windowSize = Math.min(5, lastPage);
  let start = currentPage - 2;
  start = Math.max(1, start);
  start = Math.min(start, lastPage - windowSize + 1);
  return Array.from({ length: windowSize }, (_, i) => start + i);
}

function pageUrl(n: number): string {
  return n === 1 ? baseUrl : `${baseUrl.replace(/\/$/, '')}/${n}`;
}

const pageItems = getPageItems(page.currentPage, page.lastPage);
---

{
  hasPages && (
    <nav
      class='page-nav'
      transition:animate='none'
      data-base-url={baseUrl}
      data-last-page={page.lastPage}
    >
      <div class='page-nav-arrows back-arrows'>
        {page.url.first ? (
          <a
            class='page-nav-btn'
            href={page.url.first}
            title='Go to first page'
          >
            <span class='visually-hidden'>First page</span>
            <i class='ri-skip-left-line' />
          </a>
        ) : (
          <span class='page-nav-btn disabled' aria-disabled='true'>
            <i class='ri-skip-left-line' />
          </span>
        )}

        {page.url.prev ? (
          <a
            class='page-nav-btn'
            href={page.url.prev}
            title='Go to previous page'
          >
            <span class='visually-hidden'>Previous page</span>
            <i class='ri-arrow-left-s-line' />
          </a>
        ) : (
          <span class='page-nav-btn disabled' aria-disabled='true'>
            <i class='ri-arrow-left-s-line' />
          </span>
        )}
      </div>

      <ol class='page-list'>
        {pageItems.map((item) =>
          item === page.currentPage ? (
            <li>
              <span class='page-list-item current' aria-current='page'>
                {item}
              </span>
            </li>
          ) : (
            <li>
              <a
                class='page-list-item'
                href={pageUrl(item)}
                title={`Go to page ${item}`}
              >
                {item}
              </a>
            </li>
          ),
        )}
      </ol>

      <div class='page-nav-arrows forward-arrows'>
        {page.url.next ? (
          <a class='page-nav-btn' href={page.url.next} title='Go to next page'>
            <span class='visually-hidden'>Next page</span>
            <i class='ri-arrow-right-s-line' />
          </a>
        ) : (
          <span class='page-nav-btn disabled' aria-disabled='true'>
            <i class='ri-arrow-right-s-line' />
          </span>
        )}

        {page.url.last ? (
          <a class='page-nav-btn' href={page.url.last} title='Go to last page'>
            <span class='visually-hidden'>Last page</span>
            <i class='ri-skip-right-line' />
          </a>
        ) : (
          <span class='page-nav-btn disabled' aria-disabled='true'>
            <i class='ri-skip-right-line' />
          </span>
        )}
      </div>

      <form class='go-to-page' data-paginator-form>
        <input
          type='number'
          min='1'
          max={page.lastPage}
          placeholder={`${page.currentPage}/${page.lastPage}`}
          aria-label={`Go to page (1–${page.lastPage})`}
          required
          data-paginator-input
        />
        <button type='submit'>Go to Page</button>
      </form>
    </nav>
  )
}

<style>
  .page-nav {
    display: grid;
    grid-template:
      'back-arrows page-list forward-arrows'
      'goto-page goto-page goto-page';
    grid-template-columns: 1fr auto 1fr;
    justify-items: center;

    gap: 0.6rem;

    margin-block: 2rem;
  }

  .back-arrows {
    grid-area: back-arrows;
    justify-self: end;
  }

  .forward-arrows {
    grid-area: forward-arrows;
    justify-self: start;
  }

  .page-nav-arrows {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .page-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;

    width: 2.5rem;
    height: 2.5rem;

    font-size: 1.25rem;

    text-decoration: none;
    color: var(--clr-text);
    background-color: var(--clr-surface-0);
    border: none;
    border-radius: 50%;

    cursor: pointer;

    transition-property: background-color, outline, color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  a.page-nav-btn:hover {
    background-color: var(--clr-surface-1);
    color: var(--clr-text);
  }

  .page-nav-btn.disabled {
    color: var(--clr-subtext-0);
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }

  .page-list {
    grid-area: page-list;

    display: flex;
    align-items: center;
    gap: 0.4rem;

    list-style: none;
    margin: 0;
    padding: 0;
  }

  .page-list-item {
    display: flex;
    align-items: center;
    justify-content: center;

    min-width: 2.2rem;
    height: 2.2rem;

    padding-inline: 0.4rem;

    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--clr-subtext-1);

    border-radius: 4px;

    transition-property: background-color, outline, color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  a.page-list-item:hover {
    background-color: var(--clr-surface-1);
    color: var(--clr-text);
  }

  .page-list-item.current {
    color: var(--clr-text);
    background-color: var(--clr-surface-1);
    font-weight: 700;
    pointer-events: none;
  }

  .go-to-page {
    grid-area: goto-page;

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;

    justify-self: center;
  }

  .go-to-page input {
    width: 4.5rem;
    height: 2rem;

    padding-inline: 0.5rem;

    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    text-align: center;
    color: var(--clr-text);

    background-color: var(--clr-surface-0);
    outline: 2px solid transparent;
    border: none;
    border-radius: 999px;

    appearance: textfield;

    transition-property: outline, background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .go-to-page input:hover {
    background-color: var(--clr-surface-1);
  }

  .go-to-page input::-webkit-inner-spin-button,
  .go-to-page input::-webkit-outer-spin-button {
    appearance: none;
    margin: 0;
  }

  .go-to-page input:focus {
    outline: 2px solid var(--clr-surface-2);
    background-color: var(--clr-surface-1);
  }

  .go-to-page input::placeholder {
    color: var(--clr-subtext-0);
  }

  :global(:root[data-color-scheme='dark']) .go-to-page {
    --input-clr-error-text: oklch(from var(--clr-error) calc(l + 0.2) c h);
    --input-clr-error-ph-text: oklch(from var(--clr-error) calc(l + 0.1) c h);
    --input-clr-error-background: oklch(
      from var(--clr-error) calc(l - 0.5) c h
    );
    --input-clr-error-outline: var(--clr-error);
  }

  :global(:root[data-color-scheme='light']) .go-to-page {
    --input-clr-error-text: oklch(from var(--clr-error) calc(l + 0.4) c h);
    --input-clr-error-ph-text: oklch(from var(--clr-error) calc(l + 0.4) c h);
    --input-clr-error-background: oklch(from var(--clr-error) calc(l - 0) c h);
    --input-clr-error-outline: oklch(from var(--clr-error) calc(l + 0.25) c h);
  }

  .go-to-page input:user-invalid {
    outline-color: var(--input-clr-error-outline);
    color: var(--input-clr-error-text);
    background-color: var(--input-clr-error-background);
  }

  .go-to-page input:user-invalid::placeholder {
    color: var(--input-clr-error-ph-text);
  }

  .go-to-page button {
    display: flex;
    align-items: center;
    justify-content: center;

    height: 2.5rem;

    padding-inline: 1rem;

    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--clr-text);

    background-color: var(--clr-surface-0);
    border: none;
    border-radius: 2pt;

    cursor: pointer;

    transition-property: background-color, outline, color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .go-to-page button:hover {
    background-color: var(--clr-surface-1);
    /* outline: 2px solid var(--clr-overlay-0); */
  }
</style>

<script>
  function initPaginator() {
    const forms = document.querySelectorAll<HTMLFormElement>(
      '[data-paginator-form]',
    );

    forms.forEach((form) => {
      const nav = form.closest('.page-nav') as HTMLElement;
      const input = form.querySelector<HTMLInputElement>(
        '[data-paginator-input]',
      );
      if (!nav || !input) return;

      const baseUrl = nav.dataset.baseUrl ?? '';
      const lastPage = parseInt(nav.dataset.lastPage ?? '1', 10);

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const page = parseInt(input.value, 10);
        if (isNaN(page) || page < 1 || page > lastPage) return;

        const url =
          page === 1 ? baseUrl : `${baseUrl.replace(/\/$/, '')}/${page}`;
        window.location.href = url;
      });
    });
  }

  initPaginator();
  document.addEventListener('astro:after-swap', initPaginator);
</script>
