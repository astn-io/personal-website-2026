  }

  [data-color='red']:hover {
    color: var(--clr-text-hover-red);
    background-color: var(--clr-bg-hover-red);
    outline-color: var(--clr-outline-hover-red);
  }

  [data-color='hotpink']:hover {
    color: var(--clr-text-hover-hotpink);
    background-color: var(--clr-bg-hover-hotpink);
    outline-color: var(--clr-outline-hover-hotpink);
  }

  [data-color='pink']:hover {
