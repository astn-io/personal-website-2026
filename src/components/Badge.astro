---
import { Color } from '@scripts/types';

type Props = {
  icon?: string;
  url?: string;
  color?: Color;
};

const { icon, url, color = Color.blue } = Astro.props;
---

{
  url ? (
    <a class='badge' href={url} data-color={color}>
      {icon && <span class={`badge-icon ${icon}`} />}
      <span class='badge-label'>
        <slot />
      </span>
    </a>
  ) : (
    <p class='badge' data-color={color}>
      {icon && <span class={`badge-icon ${icon}`} />}
      <span class='badge-label'>
        <slot />
      </span>
    </p>
  )
}

<style>
  a {
    text-decoration: none;
    cursor: pointer;
  }

  a:focus {
    outline-color: var(--clr-text-0);
  }

  [data-color='blue'] {
    color: var(--clr-text-blue);
    background-color: var(--clr-bg-blue);
    outline-color: var(--clr-outline-blue);
  }

  [data-color='teal'] {
    color: var(--clr-text-teal);
    background-color: var(--clr-bg-teal);
    outline-color: var(--clr-outline-teal);
  }

  [data-color='aqua'] {
    color: var(--clr-text-aqua);
    background-color: var(--clr-bg-aqua);
    outline-color: var(--clr-outline-aqua);
  }

  [data-color='green'] {
    color: var(--clr-text-green);
    background-color: var(--clr-bg-green);
    outline-color: var(--clr-outline-green);
  }

  [data-color='yellow'] {
    color: var(--clr-text-yellow);
    background-color: var(--clr-bg-yellow);
    outline-color: var(--clr-outline-yellow);
  }

  [data-color='orange'] {
    color: var(--clr-text-orange);
    background-color: var(--clr-bg-orange);
    outline-color: var(--clr-outline-orange);
  }

  [data-color='red'] {
    color: var(--clr-text-red);
    background-color: var(--clr-bg-red);
    outline-color: var(--clr-outline-red);
  }

  [data-color='hotpink'] {
    color: var(--clr-text-hotpink);
    background-color: var(--clr-bg-hotpink);
    outline-color: var(--clr-outline-hotpink);
  }

  [data-color='pink'] {
    color: var(--clr-text-pink);
    background-color: var(--clr-bg-pink);
    outline-color: var(--clr-outline-pink);
  }

  [data-color='purple'] {
    color: var(--clr-text-purple);
    background-color: var(--clr-bg-purple);
    outline-color: var(--clr-outline-purple);
  }

  [data-color='blue']:hover {
    color: var(--clr-text-hover-blue);
    background-color: var(--clr-bg-hover-blue);
    outline-color: var(--clr-outline-hover-blue);
  }

  [data-color='teal']:hover {
    color: var(--clr-text-hover-teal);
    background-color: var(--clr-bg-hover-teal);
    outline-color: var(--clr-outline-hover-teal);
  }

  [data-color='aqua']:hover {
    color: var(--clr-text-hover-aqua);
    background-color: var(--clr-bg-hover-aqua);
    outline-color: var(--clr-outline-hover-aqua);
  }

  [data-color='green']:hover {
    color: var(--clr-text-hover-green);
    background-color: var(--clr-bg-hover-green);
