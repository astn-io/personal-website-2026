---
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<div
  class='directory-hero full-width content-grid'
  transition:name='directory-hero'
  id='directory-hero'
>
  <h1>{title}</h1>
</div>

<style>
  div.directory-hero {
    position: relative;
    top: calc(var(--appbar-height) * -1);

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    background-color: var(--clr-surface-0);
    min-height: calc(50vh + var(--appbar-height));
  }
</style>
