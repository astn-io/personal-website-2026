---
import { Picture } from 'astro:assets';

type Props = {
  title: string;
  titleIcon?: string;
  subtitle?: string;
  subtitleIcon?: string;
  description?: string;
  image?: ImageMetadata;
  imageAlt?: string;
};

const {
  title,
  titleIcon,
  subtitle,
  subtitleIcon,
  description,
  image,
  imageAlt = '',
} = Astro.props;
---

<div
  class='directory-hero full-width content-grid'
  transition:name='directory-hero'
  id='directory-hero'
>
  <div class='hero-img-container full-width'>
    {
      image && (
        <Picture
          src={image}
          alt={imageAlt}
          class='hero-img'
          formats={['avif', 'webp']}
          fallbackFormat='webp'
          widths={[720, 1080, 2560, 3840]}
          sizes='(min-width: 800px) 800px, 100vw'
          loading='lazy'
          decoding='async'
        />
      )
    }
  </div>

  <div class='directory-content'>
    {
      subtitle && (
        <p class='directory-subtitle'>
          {subtitleIcon && <span class={`${subtitleIcon} subtitle-icon`} />}
          <span>{subtitle}</span>
        </p>
      )
    }
    <h1 class='directory-title'>
      {titleIcon && <span class={`${titleIcon} title-icon`} />}
      <span>{title}</span>
    </h1>
    <hr />
    {description && <p class='directory-description'>{description}</p>}
  </div>
</div>

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  :global(:root[data-color-scheme='dark']) div.directory-hero {
    --hero-clr-bg: var(--clr-base-2);
    --hero-opacity-bg: 0.6;
  }

  :global(:root[data-color-scheme='light']) div.directory-hero {
    --hero-clr-bg: transparent;
    --hero-opacity-bg: 0.8;
  }

  div.directory-hero {
    position: relative;
    isolation: isolate;

    top: calc(var(--appbar-height) * -1);

    background-color: var(--hero-clr-bg);
    min-height: calc(50vh + var(--appbar-height));

    padding-top: 5rem;

    overflow: hidden;

    width: 100%;
  }

  .directory-content {
    position: relative;

    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: center;

    height: fit-content;

    font-size: 6rem;

    margin-block: auto;
    margin-right: auto;

    padding-block: 4rem;
    padding-inline: 4rem;

    width: 100%;

    backdrop-filter: blur(10px);
  }

  .directory-content::after {
    content: '';
    position: absolute;
    inset: 0;

    background-color: var(--clr-base-0);
    outline: 1px solid var(--clr-surface-2);

    opacity: 0.8;

    border-radius: 4pt;

    z-index: -1;
  }

  .directory-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35ch;

    font-size: 3rem;
    font-weight: 300;
    letter-spacing: -0.025ch;

    margin-bottom: 0.25rem;

    transform: scaleY(95%);
  }

  p.directory-subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5ch;

    color: var(--clr-text-2);
    font-size: 1.25rem;

    margin-top: 0;
    margin-bottom: -0.25rem;
  }

  hr {
    content: '';

    display: flex;

    position: relative;

    height: 2px;
    width: 100%;

    border: none;

    background-color: var(--clr-overlay-2);

    margin: 0;
  }

  .directory-description {
    max-width: 72ch;

    font-size: 1.25rem;

    color: var(--clr-text-2);

    margin-bottom: 0;
  }

  .hero-img-container {
    display: flex;

    position: absolute;
    top: 50%;

    transform: translateY(-50%);

    z-index: -10;

    opacity: var(--hero-opacity-bg);

    width: 100%;
  }

  .hero-img-container :global(picture) {
    width: 100%;
  }

  .hero-img {
    object-fit: cover;

    width: 100%;
    height: auto;
  }

  @media screen and (width < $width-mobile-1) {
    div.directory-hero {
      top: 0;
      min-height: 14rem;
      margin-bottom: 1rem;
      padding-top: 6rem;
    }

    .directory-content {
      padding: 1rem;
    }

    .directory-title {
      font-size: 1.5rem;
    }

    p.directory-description {
      font-size: 1rem;
    }

    .hero-img-container {
      height: 100%;
    }

    .hero-img {
      height: 100%;
    }
  }
</style>
