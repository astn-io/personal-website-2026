---
type Props = {
  categories: { name: string; count: number }[];
  tags: { name: string; count: number }[];
  route: string;
};

import slugify from '@scripts/slugify';
import Tag from '@components/Tag.astro';

const { categories, tags, route } = Astro.props;

/**
 * Bin-pack tags by estimated width to minimize row gaps.
 * Approximate each tag's width as character count (hashtag + name + padding).
 * Uses first-fit-decreasing: place widest tags first, filling rows greedily.
 */
const displayTags = tags.slice(0, 8);
const TAG_PADDING = 4; // approximate padding in character-width units
const ROW_WIDTH = 30; // approximate row capacity in character-width units

function packTags(items: typeof displayTags): typeof displayTags {
  const estimated = items.map((tag) => ({
    tag,
    width: tag.name.length + TAG_PADDING,
  }));
  // Sort widest first for first-fit-decreasing
  estimated.sort((a, b) => b.width - a.width);

  const rows: { remaining: number; tags: typeof estimated }[] = [];

  for (const item of estimated) {
    // Find first row that fits this tag
    const row = rows.find((r) => r.remaining >= item.width);
    if (row) {
      row.tags.push(item);
      row.remaining -= item.width;
    } else {
      rows.push({ remaining: ROW_WIDTH - item.width, tags: [item] });
    }
  }

  return rows.flatMap((r) => r.tags.map((t) => t.tag));
}

const packedTags = packTags(displayTags);
---

<aside
  class='directory-fields-container'
  transition:name='directory-fields'
  id='directory-fields'
>
  <div class='directory-field-container categories-container'>
    <a class='directory-field-title' href={`${route}/categories`}>
      <span class='ri-apps-2-line'></span>
      <span>Categories</span>
    </a>
    <ul class='categories-list'>
      {
        categories.slice(0, 4).map(({ name, count }) => (
          <li>
            <a
              class='category-label'
              href={`${route}/categories/${slugify(name)}`}
            >
              <p>{name}</p>
              <div class='separator' />
              <p class='category-count'>{count}</p>
            </a>
          </li>
        ))
      }
    </ul>
    <a class='btn-view-all' href={`${route}/categories`}>
      <span>View All</span>
      <span class='ri-arrow-right-line btn-view-all-icon'></span>
    </a>
  </div>
  <div class='directory-field-container tags-container'>
    <a class='directory-field-title' href={`${route}/tags`}>
      <span class='ri-price-tag-line'></span>
      <span>Tags</span>
    </a>
    <ul class='tags-list'>
      {
        packedTags.map((tag) => (
          <li>
            <Tag url={`${route}/tags/${slugify(tag.name)}`} label={tag.name} />
          </li>
        ))
      }
    </ul>
    <a class='btn-view-all' href={`${route}/tags`}>
      <span>View All</span>
      <span class='ri-arrow-right-line btn-view-all-icon'></span>
    </a>
  </div>
</aside>

<style>
  p {
    margin: 0;
  }

  a {
    text-decoration: none;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;

    list-style-type: none;
    padding-inline: 1rem;
    margin: 0;
  }

  .directory-fields-container {
    position: sticky;
    top: 0;
    align-self: start;

    display: flex;
    flex-direction: column;
    gap: 2rem;

    padding-top: 1rem;

    transition: top 200ms ease-out;
  }

  :global(:root[data-appbar-hidden='false']) .directory-fields-container {
    top: calc(var(--appbar-height) + 1rem);
  }

  :global(:root[data-appbar-hidden='true']) .directory-fields-container {
    top: 0;
  }

  .directory-field-container {
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    background-color: var(--clr-surface-0);

    border-radius: 4pt;
    overflow: hidden;

    min-height: fit-content;

    outline: 1px solid var(--clr-surface-1);
  }

  .directory-field-title {
    display: flex;
    align-items: center;
    justify-content: start;
    gap: 0.25rem;

    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-subtext-0);
    text-transform: uppercase;
    letter-spacing: 0.2ch;

    background-color: var(--clr-surface-1);

    padding-inline: 1rem;
    padding-block: 0.8rem;

    margin: 0;

    width: 100%;

    transition-property: color, background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .directory-field-title:hover {
    background-color: var(--clr-surface-2);
    color: var(--clr-text);
  }

  ul.categories-list {
    flex-direction: column;
    gap: 0.6rem;
    padding-inline: 1rem;
    padding-block: 1rem;
  }

  .category-label {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;

    font-size: 0.85rem;
    font-weight: 500;
    color: var(--clr-subtext-0);

    background-color: oklch(
      from var(--clr-surface-0) calc(l + 0.05) calc(c + 0.01) h
    );

    border-radius: 4pt;

    margin: 0;

    padding-block: 0.6rem;
    padding-inline: 1rem;

    width: 100%;

    transition-property: color, background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .category-label:hover {
    background-color: var(--clr-surface-1);
    color: var(--clr-text);
  }

  .category-count {
    display: flex;
    align-items: center;
    justify-content: center;

    font-weight: 600;

    background-color: var(--clr-surface-2);

    border-radius: 50%;

    height: 1.6rem;
    width: 1.6rem;

    aspect-ratio: 1;
  }

  .tags-list {
    display: flex;
    gap: 0.5rem 0.35rem;
    padding-block: 1rem;
  }

  .separator {
    display: flex;

    content: '';

    position: relative;
    bottom: 0.3rem;

    border-bottom: 0.135rem dotted var(--clr-subtext-0);

    margin-inline: auto;

    width: calc(100% - 0.5rem);
    height: 100%;

    opacity: 0.6;

    visibility: hidden;
  }

  .btn-view-all {
    display: flex;
    justify-content: space-between;

    position: relative;

    margin-top: 0.5rem;

    padding-top: 0.75rem;
    padding-bottom: 0.5rem;
    padding-inline: 1rem;

    font-weight: 700;
    color: var(--clr-subtext-0);

    outline: 0.1rem solid var(--clr-surface-1);

    transition-property: color, background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .btn-view-all:hover {
    color: var(--clr-text);
    background-color: var(--clr-surface-1);
    outline-color: var(--clr-surface-2);
  }

  .btn-view-all-icon {
    font-size: 1.25rem;

    transition-property: transform;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  .btn-view-all:hover > .btn-view-all-icon {
    transform: translateX(-0.5rem);
  }

  @media screen and (width < 1080px) {
    .directory-fields-container {
      position: relative;

      display: grid;
      grid-template-columns: 1fr 1fr;
      flex-direction: row;
    }

    :global(:root[data-appbar-hidden='false']) .directory-fields-container {
      top: 0;
    }

    :global(:root[data-appbar-hidden='true']) .directory-fields-container {
      top: 0;
    }
  }

  @media screen and (width < 600px) {
    .directory-fields-container {
      display: flex;
      flex-direction: column;
    }
  }
</style>
