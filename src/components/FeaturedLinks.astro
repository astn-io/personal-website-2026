---
import FeaturedLink from '@components/FeaturedLink.astro';
import externalLinks from '@content/externalLinks.json';

const links = externalLinks
  .flatMap((group) => group.links)
  .filter((link) => link.featured);
---

<ul>
  {
    links.map((link) => (
      <li>
        <FeaturedLink label={link.label} url={link.url} icon={link.icon} />
      </li>
    ))
  }
</ul>

<style>
  ul {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;

    list-style-type: none;
    padding: 0;
    margin: 0;
  }
</style>
