---
import Button from '@components/Button.svelte';
import SocialLinks from '@components/SocialLinks.astro';

type CallToAction = {
  label: string;
  url?: string;
};

type Props = {
  title?: string;
  subtitle?: string;
  summary?: string;
  callToAction?: CallToAction;
  enableSocialLinks?: boolean;
};

const {
  title,
  subtitle,
  summary,
  callToAction,
  enableSocialLinks = false,
} = Astro.props;
---

<section class='hero'>
  {title && <h1 class='title-l'>{title}</h1>}
  {subtitle && <h2 class='heading-4'>{subtitle}</h2>}
  <hr />
  {enableSocialLinks && <SocialLinks />}
  {summary && <p>{summary}</p>}
  {
    callToAction && (
      <Button link={callToAction.url} label={callToAction!.label} />
    )
  }
</section>

<style>
  section.hero {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: center;

    min-height: 100svh;
  }

  hr {
    height: 1px;

    width: 100%;
    max-width: 10rem;
  }
</style>
