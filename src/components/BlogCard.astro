---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Button from './Button.svelte';

interface Props {
  post: CollectionEntry<'blog'>;
  skew?: boolean;
}

const { post, skew = true } = Astro.props;

const postImg: ImageMetadata = post.data.coverImage as ImageMetadata;
---

<article data-skew={skew}>
  {
    post.data.coverImage && (
      <a href={`/blog/${post.id}`} class='card-img-link' data-skew={skew}>
        <Picture
          width={800}
          height={800}
          src={postImg}
          alt={post.data.coverAlt ? post.data.coverAlt : ''}
          class='card-img'
          transition:name={`blog-cover-${post.data.title}`}
          formats={['avif', 'webp', 'png']}
        />
      </a>
    )
  }
  <div class='card-content' data-skew={skew}>
    <h3 class='truncate card-title'>
      <a href={`/blog/${post.id}`}>{post.data.title}</a>
    </h3>
    <div class='card-meta-container'>
      <p class='card-pubdate'>
        <span class='ri-calendar-line'></span>
        <span>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </span>
      </p>
    </div>
    <p class='card-description truncate-2'>{post.data.description}</p>
    <Button
      label='Read More'
      variant='secondary'
      link={`/blog/${post.id}`}
      iconPosition='right'
      icon='ri-arrow-right-line'
      style='simple'
    />
  </div>
</article>

<style>
  article {
    --skew: 20deg;
    --image-width: 5.5rem;
    --background-position-adjust: 3rem;
    --card-border-radius: 16pt;

    isolation: isolate;
    position: relative;

    display: grid;
    gap: 1rem;

    width: calc(100% + 2rem);

    transition-property: background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  article::after {
    content: '';
    position: absolute;
    top: 0;

    height: 100%;

    background-color: var(--clr-surface-0);

    border-radius: var(--card-border-radius);

    z-index: -1;

    transition: background-color 200ms ease-out;
  }

  article[data-skew='false']::after {
    width: 100%;
    left: 0;
  }

  article[data-skew='true']::after {
    transform: skew(var(--skew));
    width: calc(100% - var(--image-width));
    left: -1rem;
  }

  article:hover::after {
    background-color: var(--clr-surface-1);
  }

  article:nth-child(odd) {
    grid-template-columns: 2fr 3fr;
    grid-template-areas: 'image content';
  }

  article[data-skew='true']:nth-child(odd)::after {
    left: var(--background-position-adjust);
  }

  article:nth-child(even) {
    grid-template-columns: 3fr 2fr;
    grid-template-areas: 'content image';
  }

  article[data-skew='true']:nth-child(even)::after {
    left: var(--background-position-adjust);
  }

  .card-content {
    grid-area: content;

    display: grid;
    grid-template-rows: auto auto 1fr auto;

    max-width: 100%;

    padding-block: 1rem;
  }

  article[data-skew='true']:nth-child(odd) > .card-content {
    padding-right: 7rem;
    margin-left: 4rem;
    padding-left: 1rem;
  }

  article[data-skew='true']:nth-child(even) > .card-content {
    padding-left: 7rem;
    margin-right: 4rem;
    padding-right: 1rem;
  }

  article[data-skew='false']:nth-child(odd) > .card-content {
    padding-right: 1rem;
  }

  article[data-skew='false']:nth-child(even) > .card-content {
    padding-left: 1rem;
  }

  h3 a {
    isolation: isolate;
    position: relative;

    color: var(--clr-text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--clr-primary);
  }

  h3 a::after {
    content: '';
    position: absolute;
    bottom: -0.2ch;
    left: 0;

    width: 0;
    height: 2px;

    background-color: var(--clr-primary);

    transition: width 100ms ease-out;
  }

  h3 a:hover::after {
    width: 100%;
  }

  h3.card-title {
    font-size: 1.5rem;
    font-weight: 500;

    margin-left: -4rem;
  }

  .card-content[data-skew='false'] h3.card-title {
    margin-left: 0;
  }

  .card-meta-container {
    display: flex;
    align-items: start;

    margin-block: 0.25rem;

    height: fit-content;

    margin-left: -3rem;
  }

  .card-content[data-skew='false'] .card-meta-container {
    margin-left: 0;
  }

  p.card-pubdate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5ch;

    font-size: 0.85rem;
    color: var(--clr-subtext-0);

    padding: 0;
    margin: 0;
  }

  p.card-description {
    color: var(--clr-subtext-1);

    margin-left: -1.5rem;
  }

  .card-content[data-skew='false'] p.card-description {
    margin-left: 0;
  }

  /* --- Card Image --- */

  a.card-img-link {
    isolation: isolate;
    position: relative;

    grid-area: image;

    display: flex;
    align-items: center;
    justify-content: center;

    height: 100%;

    border-radius: var(--card-border-radius);

    overflow: hidden;

    outline: 0.2rem solid transparent;
    outline-offset: -1px;

    transition: outline 200ms ease-out;
  }

  a.card-img-link[data-skew='true'] {
    transform: skewX(var(--skew));
  }

  a.card-img-link:hover {
    outline: 0.3rem solid var(--clr-primary);
  }

  article[data-skew='false']:nth-child(odd) > a.card-img-link {
    left: 0;
  }

  article[data-skew='false']:nth-child(even) > a.card-img-link {
    right: 0;
  }

  article[data-skew='true']:nth-child(odd) > a.card-img-link {
    left: 2.5rem;
  }

  article[data-skew='true']:nth-child(even) > a.card-img-link {
    right: 2.5rem;
  }

  picture {
    height: 100%;
    width: 100%;

    aspect-ratio: 21 / 9;
  }

  a.card-img-link[data-skew='true'] picture {
    transform: skewX(calc(var(--skew) * -1)) scale(1.3);
  }

  img.card-img {
    height: 100%;
    width: 100%;

    object-fit: cover;
    object-position: center;
  }

  a.card-img-link picture {
    filter: grayscale(40%);
    opacity: 0.8;

    transition-property: filter, transform, opacity;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  article:hover > a.card-img-link picture {
    filter: grayscale(0);
    opacity: 1;
  }

  a.card-img-link[data-skew='true'] picture:hover {
    transform: skew(calc(var(--skew) * -1)) scale(1.32);
  }

  a.card-img-link[data-skew='false'] picture:hover {
    transform: scale(1.05);
  }
</style>
