---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const postImg: ImageMetadata = post.data.coverImage as ImageMetadata;
---

<article>
  {
    post.data.coverImage && (
      <a href={`/blog/${post.id}`} class='card-img-link'>
        <Picture
          width={800}
          height={800}
          src={postImg}
          alt={post.data.coverAlt ? post.data.coverAlt : ''}
          class='card-img'
          transition:name={`blog-cover-${post.data.title}`}
          formats={['avif', 'webp', 'png']}
        />
      </a>
    )
  }
  <div class='card-content'>
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    <p>{post.data.pubDate}</p>
  </div>
</article>

<style>
  article {
    display: grid;

    gap: 1rem;

    background-color: var(--clr-surface-0);

    border-radius: 8pt;

    overflow: hidden;

    transition-property: background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  article:nth-child(odd) {
    grid-template-columns: 40% 60%;
    grid-template-areas: 'image content';
  }

  article:nth-child(even) {
    grid-template-columns: 60% 40%;
    grid-template-areas: 'content image';
  }

  article:hover {
    background-color: var(--clr-surface-1);
  }

  .card-content {
    grid-area: content;

    padding: 1rem;
  }

  a.card-img-link {
    grid-area: image;

    display: flex;
    align-items: center;
    justify-content: center;

    height: 100%;

    overflow: hidden;
  }

  picture {
    height: 100%;
    width: 100%;

    aspect-ratio: 16 / 9;
  }

  img.card-img {
    height: 100%;
    width: 100%;

    object-fit: cover;
    object-position: center;
  }
</style>
