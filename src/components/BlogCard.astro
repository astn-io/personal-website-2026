---
import type { CollectionEntry } from 'astro:content';
import BlogCardContent from './BlogCardContent.astro';
import Card from './Card.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  skew?: boolean;
}

const { post, skew = true } = Astro.props;
---

<Card
  image={post.data.coverImage as ImageMetadata}
  imageAlt={post.data.coverAlt as string}
  id={post.data.title}
  skew={skew}
>
  <BlogCardContent post={post} skew={skew} />
</Card>
