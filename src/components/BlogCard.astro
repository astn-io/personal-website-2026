---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Button from './Button.svelte';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const postImg: ImageMetadata = post.data.coverImage as ImageMetadata;
---

<article>
  {
    post.data.coverImage && (
      <a href={`/blog/${post.id}`} class='card-img-link'>
        <Picture
          width={800}
          height={800}
          src={postImg}
          alt={post.data.coverAlt ? post.data.coverAlt : ''}
          class='card-img'
          transition:name={`blog-cover-${post.data.title}`}
          formats={['avif', 'webp', 'png']}
        />
      </a>
    )
  }
  <div class='card-content'>
    <h3 class='truncate card-title'>
      <a href={`/blog/${post.id}`}>{post.data.title}</a>
    </h3>
    <div class='card-meta-container'>
      <p class='card-pubdate'>
        <span class='ri-calendar-line'></span>
        <span>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </span>
      </p>
    </div>
    <p class='card-description truncate-2'>{post.data.description}</p>
    <Button
      label='Read More'
      variant='secondary'
      link={`/blog/${post.id}`}
      iconPosition='right'
      icon='ri-arrow-right-line'
      style='simple'
    />
  </div>
</article>

<style>
  article {
    display: grid;
    gap: 1rem;

    background-color: var(--clr-surface-0);

    border-radius: 8pt;

    overflow: hidden;

    transition-property: background-color;
    transition-duration: 200ms;
    transition-timing-function: ease-out;
  }

  article:nth-child(odd) {
    grid-template-columns: 2fr 3fr;
    grid-template-areas: 'image content';
  }

  article:nth-child(even) {
    grid-template-columns: 3fr 2fr;
    grid-template-areas: 'content image';
  }

  article:hover {
    background-color: var(--clr-surface-1);
  }

  h3 a {
    isolation: isolate;
    position: relative;

    color: var(--clr-text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--clr-primary);
  }

  h3 a::after {
    content: '';
    position: absolute;
    bottom: -0.2ch;
    left: 0;

    width: 0;
    height: 2px;

    background-color: var(--clr-primary);

    transition: width 100ms ease-out;
  }

  h3 a:hover::after {
    width: 100%;
  }

  .card-content {
    grid-area: content;

    display: grid;
    grid-template-rows: auto auto 1fr auto;

    max-width: 100%;

    padding-block: 1rem;
  }

  article:nth-child(odd) > .card-content {
    padding-right: 1rem;
  }

  article:nth-child(even) > .card-content {
    padding-left: 1rem;
  }

  a.card-img-link {
    grid-area: image;

    display: flex;
    align-items: center;
    justify-content: center;

    height: 100%;

    overflow: hidden;
  }

  picture {
    height: 100%;
    width: 100%;

    aspect-ratio: 16 / 9;
  }

  img.card-img {
    height: 100%;
    width: 100%;

    object-fit: cover;
    object-position: center;
  }

  h3.card-title {
    font-size: 1.5rem;
    font-weight: 500;
  }

  p.card-description {
    color: var(--clr-subtext-1);
  }

  .card-meta-container {
    display: flex;
    align-items: start;

    margin-block: 0.25rem;

    height: fit-content;
  }

  p.card-pubdate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5ch;

    font-size: 0.85rem;
    color: var(--clr-subtext-0);

    padding: 0;
    margin: 0;
  }
</style>
