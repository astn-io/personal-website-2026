---
import type { CollectionEntry } from 'astro:content';
import Card from '@components/Card.astro';
import FrontendProjectCardContent from '@components/cards/FrontendProjectCardContent.astro';

interface Props {
  project: CollectionEntry<'frontendProjects'>;
  skew?: boolean;
  inList?: boolean;
}

const { project, skew = true, inList = false } = Astro.props;
---

<Card
  image={project.data.coverImage as ImageMetadata}
  imageAlt={project.data.coverAlt as string}
  inList={inList}
  skew={skew}
  link=`/projects/frontend/${project.id}`
>
  <FrontendProjectCardContent project={project} skew={skew} />
</Card>
