---
import type { CollectionEntry } from 'astro:content';
import BlogCardContent from '@components/cards/BlogCardContent.astro';
import Card from '@components/Card.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  skew?: boolean;
  inList?: boolean;
}

const { post, skew = true, inList = false } = Astro.props;
---

<Card
  image={post.data.coverImage as ImageMetadata}
  imageAlt={post.data.coverAlt as string}
  skew={skew}
  link=`/blog/${post.id}`
  inList={inList}
>
  <BlogCardContent post={post} skew={skew} />
</Card>
