---
import SocialCard from '@components/SocialCard.astro';
import externalLinks from '@content/externalLinks.json';

const allLinks = externalLinks
  .flatMap((group) => group.links)
  .filter((link) => link.enabled);
---

<ul class='social-cards-list'>
  {
    allLinks.map((link) => (
      <li class='social-cards-list-item'>
        <SocialCard
          label={link.label}
          icon={link.icon}
          url={link.url}
          username={link.username}
        />
      </li>
    ))
  }
</ul>

<style>
  ul.social-cards-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;

    list-style-type: none;
    padding: 0;
  }

  li.social-cards-list-item {
    width: 100%;
    max-width: 26rem;
  }

  li.social-cards-list-item:nth-child(odd) {
    justify-self: end;
  }

  li.social-cards-list-item:nth-child(even) {
    justify-self: start;
  }
</style>
