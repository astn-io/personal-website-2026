---
import internalLinks from '@content/internalLinks.json';
import externalLinks from '@content/externalLinks.json';

const currentYear = new Date().getFullYear();

const allowedGroups = ['Development', 'Social'];

const filteredLinkGroups = externalLinks
  .filter((group) => allowedGroups.includes(group.label))
  .map((group) => ({
    ...group,
    links: group.links.filter((link) => link.enabled),
  }))
  .filter((group) => group.links.length > 0);
---

<footer class='content-grid'>
  <div class='footer-body'>
    <div class='footer-brand'>
      <div class='footer-brand-title'>
        <a href='/' class='footer-brand-name'>Austin Hagel</a>
        <p class='footer-brand-tagline'>Developer & Designer</p>
      </div>
      <p class='footer-brand-description'>
        A web development specialist with a knack for design.
      </p>
    </div>
    <div class='links-container'>
      <nav class='footer-nav' aria-label='Footer navigation'>
        <p class='footer-group-label'>
          <span class='ri-map-pin-line' aria-hidden='true'></span>
          Pages
        </p>
        <hr />
        <ul>
          {
            internalLinks.map((link) => (
              <li>
                <a href={link.url}>
                  <span class={link.icon} aria-hidden='true' />
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {
        filteredLinkGroups.map((group) => (
          <div class='footer-link-group'>
            <p class='footer-group-label'>
              <span class={group.icon} aria-hidden='true' />
              {group.label}
            </p>
            <hr />
            <ul>
              {group.links.map((link) => (
                <li>
                  <a href={link.url} target='_blank' rel='noopener noreferrer'>
                    <span class={link.icon} aria-hidden='true' />
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class='footer-bottom'>
    <p>© {currentYear} Austin Hagel</p>
  </div>
</footer>

<style lang='scss'>
  @use '../styles/variables.scss' as *;

  footer {
    margin-top: 12rem;
    background-color: var(--clr-surface-0);
    border-top: 1px solid var(--clr-surface-2);
    width: 100%;
  }

  hr {
    margin-block: 0.25rem;
  }

  /* ── Body row ───────────────────────────────────────────── */

  .footer-body {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    gap: 2.5rem 2rem;
    padding-block: 3rem;
  }

  /* ── Brand ─────────────────────────────────────────────── */

  .footer-brand {
    display: flex;
    align-items: end;
    gap: 1.5rem;
  }

  .footer-brand-name {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.015rem;
    color: var(--clr-text-0);
    text-decoration: none;
    width: fit-content;
    transition: color 150ms ease-out;

    &:hover {
      color: var(--clr-primary);
    }
  }

  .footer-brand-tagline {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--clr-text-1);
    letter-spacing: 0.03rem;
  }

  .footer-brand-description {
    margin: 0.5rem 0 0;
    font-size: 0.825rem;
    color: var(--clr-text-2);
    max-width: 22ch;
    line-height: 1.6;
  }

  /* ── Nav & Link groups ──────────────────────────────────── */

  .links-container {
    display: flex;
    gap: 4rem;
  }

  .footer-nav,
  .footer-link-group {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  /* ── Section labels ─────────────────────────────────────── */

  .footer-group-label {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;

    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1ch;

    span {
      font-size: 0.85rem;
    }
  }

  /* ── Links ──────────────────────────────────────────────── */

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  li a {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    color: var(--clr-text-1);
    text-decoration: none;
    transition: color 150ms ease-out;

    span {
      font-size: 0.95rem;
      opacity: 0.65;
      transition: opacity 150ms ease-out;
    }

    &:hover {
      color: var(--clr-primary);

      span {
        opacity: 1;
      }
    }
  }

  /* ── Bottom bar ─────────────────────────────────────────── */

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.25rem;
    border-top: 1px solid var(--clr-surface-2);

    p {
      margin: 0;
      font-size: 0.78rem;
      color: var(--clr-text-2);
      letter-spacing: 0.02rem;
    }
  }

  /* ── Responsive ─────────────────────────────────────────── */

  @media screen and (width < $width-mobile-2) {
    .footer-brand {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }

    .footer-brand-description {
      margin: 0;
    }

    .links-container {
      flex-wrap: wrap;
      gap: 2rem;
    }
  }

  @media screen and (width < $width-mobile-1) {
    footer {
      margin-top: 6rem;
    }

    .footer-body {
      padding-block: 2.5rem;
      gap: 2rem;
    }

    .links-container {
      gap: 1.5rem;
    }
  }
</style>
