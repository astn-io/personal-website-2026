---
import PlatformCard from '@components/PlatformCard.astro';

type Platform = {
  label: string;
  icon: string;
  url: string;
  username: string;
};

type Props = {
  platformList: Platform[];
  onSurface?: boolean;
};

const { platformList, onSurface = false } = Astro.props;
---

<ul class='platform-list'>
  {
    platformList.map((platform) => (
      <li class='platform-list-item'>
        <PlatformCard
          label={platform.label}
          icon={platform.icon}
          url={platform.url}
          username={platform.username}
          onSurface={onSurface}
        />
      </li>
    ))
  }
</ul>

<style>
  ul.platform-list {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;

    list-style-type: none;
    padding: 0;
  }

  li.platform-list-item {
    width: 100%;
    /* max-width: 26rem; */
  }

  li.platform-list-item:nth-child(odd) {
    justify-self: end;
  }

  li.platform-list-item:nth-child(even) {
    justify-self: start;
  }

  @media screen and (width < 600px) {
    ul.platform-list {
      display: flex;
      flex-direction: column;
    }
  }
</style>
