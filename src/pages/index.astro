---
import Base from '@layouts/Base.astro';
import HeroSection from '@components/sections/HeroSection.astro';
import AboutSection from '@components/sections/AboutSection.astro';
import ProjectsSection from '@components/sections/ProjectsSection.astro';
import BlogSection from '@components/sections/BlogSection.astro';
import LinksSection from '@/components/sections/LinksSection.astro';
---

<Base title='Austin Hagel - Developer, Designer, Creator'>
  <HeroSection
    variant='primary'
    title='Austin Hagel'
    subtitle='Developer | Designer | Creator'
    summary='A web development specialist with a knack for design.'
    enableSocialLinks={false}
    primaryCta={{ url: '/#projects', label: 'View Work' }}
    secondaryCta={{ url: '/#about', label: 'Learn More' }}
  />
  <div class='spacer'></div>
  <AboutSection title='About' />
  <div class='spacer'></div>
  <BlogSection />
  <div class='spacer'></div>
  <ProjectsSection />
  <div class='spacer'></div>
  <LinksSection />
</Base>

<style>
  .spacer {
    margin-block: 4rem;
  }
</style>
