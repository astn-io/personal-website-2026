---
import AboutSection from '@/components/sections/AboutSection.astro';
import HeroSection from '@components/sections/HeroSection.astro';
import Base from '@layouts/Base.astro';
import testImage from '@assets/images/test-image-1.jpg';
---

<Base>
  <HeroSection
    title='Austin Hagel'
    subtitle='Developer & Designer'
    summary="I am a very good designer! I'm not good at creating placeholder text, though. Lorem ipsum."
    enableSocialLinks={true}
    primaryCta={{ url: '/', label: 'View Work' }}
    secondaryCta={{ url: '/#about', label: 'About Me' }}
  />
  <AboutSection
    title='About'
    paragraph='Hello, this is the about section.'
    imageSrc={testImage}
  />
</Base>
