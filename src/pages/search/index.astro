---
import '@styles/search.scss';
import Base from '@layouts/Base.astro';
import DirectoryHero from '@components/DirectoryHero.astro';
import bg from '@assets/images/search-bg.jpg';

/*

NOTE REGARDING THE CARD TEMPLATE:

This is actually NOT an astro component!
It is just a template literal inside the script file.
Specifically, it is the file in the
./src/scripts/search/resultTemplate.ts file. There is
a function there that returns the actual template. Modify that
file if you need to add classes or anything to the card itself.

*/
---

<Base title={`Search the site`}>
  <DirectoryHero
    title='Search'
    titleIcon='ri-search-2-line'
    description='Search for content across the site.'
    image={bg}
  />

  <div class='search-page-container'>
    <div class='search-results-header'>
      <p class='section-title' id='search-readout'>Start a search</p>
      <span id='search-count' aria-live='polite'></span>
    </div>

    <section aria-label='Search Results' class='search-results-section'>
      <div class='loading-icon'>
        <i id='spinner' class='ri-loader-2-fill' data-active='false'></i>
      </div>
      <ul id='search-results'></ul>
      <div id='search-state' class='search-state' hidden>
        <span
          id='search-state-icon'
          class='search-state-icon ri-search-2-line'
          aria-hidden='true'></span>
        <p id='search-state-title' class='search-state-title'>
          Start typing to search
        </p>
        <p id='search-state-text' class='search-state-text'>
          Use the search bar above to look across blog posts, guides, and
          frontend projects.
        </p>
      </div>
    </section>

    <div id='search-paginator'></div>
  </div>
</Base>

<script src='@scripts/search/search.ts'></script>
