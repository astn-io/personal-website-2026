---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Base from '@layouts/Base.astro';
import Tag from '@components/Tag.astro';
import Chip from '@components/Chip.astro';
import slugify from '@scripts/slugify';
import Badge from '@/components/Badge.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} | Austin Hagel`}>
  {
    post.data.coverImage && post.data.coverAlt && (
      <div class='post-cover-container'>
        <Picture
          src={post.data.coverImage}
          alt={post.data.coverAlt}
          class={`post-cover`}
        />
      </div>
    )
  }
  {!post.data.coverImage && <div class='spacer' />}
  <h1>{post.data.title}</h1>
  <div class='post-info-container'>
    {
      post.data.category && (
        <Badge url={`/blog/categories/${slugify(post.data.category)}`}>
          {post.data.category}
        </Badge>
      )
    }
    <div class='post-date-info-container'>
      <Chip icon='ri-calendar-line'>
        <span>Published: </span>
        {
          post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })
        }
      </Chip>
      {
        post.data.updatedDate && (
          <>
            <span>Updated: </span>
            <Chip icon='ri-calendar-line'>
              {post.data.updatedDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </Chip>
          </>
        )
      }
    </div>

    {
      post.data.tags && (
        <ul class='tags-list'>
          {post.data.tags.map((tag) => (
            <li class='tags-list-item'>
              <Tag
                label={tag}
                style='simple'
                url={`/blog/tags/${slugify(tag)}`}
              />
            </li>
          ))}
        </ul>
      )
    }
  </div>
  <article>
    <Content />
  </article>
</Base>

<style lang='scss'>
  @use '../../styles/variables.scss' as *;

  .spacer {
    content: '';
    height: 2.5rem;
  }

  h1 {
    margin-top: 1rem;
    margin-bottom: 0.75rem;
    line-height: 1.75ch;
  }

  article {
    background-color: var(--clr-surface-0);
    padding-inline: 2rem;
    padding-block: 1rem;

    border-radius: 16pt;
  }

  .post-cover-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;

    margin-top: 6rem;
    overflow: hidden;
    border-radius: 16pt;
  }

  .post-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    width: 100%;
    height: auto;
    object-fit: cover;
    z-index: -1;
  }

  .post-info-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    margin-bottom: 2rem;
  }

  ul.tags-list {
    display: flex;
    gap: 1rem;

    padding: 0;
    margin: 0;

    list-style-type: none;
  }

  .post-date-info-container {
    display: flex;
    flex-direction: column;
    align-items: start;
  }

  @media screen and (width < $width-mobile-2) {
    article {
      padding: 0;
      background-color: transparent;
    }
  }
</style>
