---
import { getCollection, render } from 'astro:content';
import { Picture, getImage } from 'astro:assets';
import Base from '@layouts/Base.astro';
import Tag from '@components/Tag.astro';
import Chip from '@components/Chip.astro';
import slugify from '@scripts/slugify';
import Badge from '@/components/Badge.astro';
import ShareButton from '@components/ShareButton.astro';
import { colorFromString } from '@scripts/colorFromString';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const keywords = [
  ...(post.data.category ? [post.data.category] : []),
  ...(post.data.tags ? post.data.tags : []),
];

const siteUrl = 'https://test.astn.io'; // or extract this to a shared config

const ogImageData = post.data.coverImage
  ? await getImage({
      src: post.data.coverImage,
      width: 1200,
      height: 630,
      format: 'png',
    })
  : null;

const ogImage = ogImageData ? `${siteUrl}${ogImageData.src}` : undefined;

console.log(ogImage);
---

<Base
  title={`${post.data.title} | Austin Hagel`}
  keywords={keywords}
  author={post.data.author ? post.data.author : ''}
  description={post.data.description}
  ogImage={ogImage}
>
  {
    post.data.coverImage && post.data.coverAlt && (
      <div class='post-cover-container'>
        <Picture
          src={post.data.coverImage}
          alt={post.data.coverAlt}
          class={`post-cover`}
        />
      </div>
    )
  }
  {!post.data.coverImage && <div class='spacer' />}
  <div class='post-title-container'>
    <h1 class='post-title'>{post.data.title}</h1>
    <div class='post-share-container'>
      <ShareButton
        title={post.data.title}
        description={post.data.description}
      />
    </div>
  </div>

  <div class='post-info-container'>
    <div class='post-date-info-container'>
      <div class='date-info-item'>
        <p class='published-label'>Date Published</p>
        <Chip icon='ri-calendar-line'>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </Chip>
      </div>
      {
        post.data.updatedDate && (
          <div class='date-info-item'>
            <p class='published-label'>Last Update</p>
            <Chip icon='ri-calendar-line'>
              {post.data.updatedDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </Chip>
          </div>
        )
      }
    </div>

    <div class='post-meta-row'>
      {
        post.data.category && (
          <Badge
            icon='ri-folder-3-line'
            url={`/blog/categories/${slugify(post.data.category)}`}
            color={colorFromString(post.data.category)}
          >
            {post.data.category}
          </Badge>
        )
      }
      {
        post.data.tags && (
          <ul class='tags-list'>
            {post.data.tags.map((tag) => (
              <li class='tags-list-item'>
                <Tag
                  label={tag}
                  style='simple'
                  url={`/blog/tags/${slugify(tag)}`}
                />
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>

  <article>
    <Content />
  </article>
</Base>

<style lang='scss'>
  @use '../../styles/variables.scss' as *;

  .post-title-container {
    display: flex;
    align-items: center;
    gap: 1rem;

    width: 100%;

    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .spacer {
    content: '';
    height: 2.5rem;
  }

  p.published-label {
    font-size: 0.85rem;
    margin: 0;
    color: var(--clr-text-2);
  }

  h1 {
    margin: 0;
    line-height: 1.75ch;
  }

  article {
    background-color: var(--clr-surface-0);
    padding-inline: 2rem;
    padding-block: 1rem;

    border-radius: 16pt;
  }

  .post-cover-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;

    margin-top: 6rem;
    overflow: hidden;
    border-radius: 16pt;
  }

  .post-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    width: 100%;
    height: auto;
    object-fit: cover;
    z-index: -1;
  }

  .post-info-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    margin-bottom: 1rem;
  }

  .post-meta-row {
    display: flex;
    flex-direction: column;
    align-items: end;
    gap: 0.6rem;
  }

  ul.tags-list {
    display: flex;
    justify-content: end;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;

    padding: 0;
    margin: 0;

    list-style-type: none;
  }

  .post-date-info-container {
    display: flex;
    flex-shrink: 0;
    gap: 2rem;
  }

  .post-share-container {
    display: flex;
    align-items: center;
    justify-content: center;

    margin-left: auto;
  }

  @media screen and (width < $width-mobile-2) {
    h1 {
      font-size: 2rem;
    }

    article {
      padding: 0;
      background-color: transparent;
    }

    .post-title-container {
      flex-direction: column;
      align-items: start;
    }

    .post-share-container {
      margin-left: 0;
    }

    .post-info-container {
      flex-direction: column;
      align-items: start;
    }

    .post-meta-row {
      align-items: start;
    }
  }
</style>
