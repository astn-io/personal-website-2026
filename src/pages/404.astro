---
import Base from '../layouts/Base.astro';
---

<Base title='404 Page Not Found'>
  <section>
    <h1>404</h1>
    <p>Page not found</p>
    <a href='/'>Go Home</a>
  </section>
</Base>

<style>
  section {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;

    width: 100%;
    height: 100%;

    margin-block: auto;

    background: none;
  }

  h1 {
    font-size: 6rem;
    margin: 0;
  }

  p {
    margin: 0;
    font-size: 2rem;
    text-transform: uppercase;
  }

  a {
    margin-top: 2rem;
  }
</style>
