---
import Base from '@layouts/Base.astro';
import AboutSectionImage from '@components/sections/AboutSectionImage.astro';
import StyledHr from '@components/StyledHr.astro';
import Button from '@components/Button.svelte';
import SocialLink from '@components/SocialLink.astro';
import externalLinks from '@content/externalLinks.json';
import Picture from 'astro/components/Picture.astro';
import testImg from '@assets/images/test-image-1.jpg';
import testImg2 from '@assets/images/test-image-2.jpg';

const enabledLinks = externalLinks
  .flatMap((group) => group.links)
  .filter((link) => link.enabled);
---

<Base
  title='About'
  description='Learn about Austin Hagel — a developer and designer who curates code like a fine art.'
>
  <!-- Intro -->
  <section class='about-intro'>
    <div class='intro-image'>
      <AboutSectionImage src={testImg} alt='Austin Hagel' />
    </div>
    <div class='intro-content'>
      <p class='intro-label'>About</p>
      <h1>Austin <span class='text-accent'>Hagel</span></h1>
      <StyledHr />
      <p class='intro-tagline'>Curating code like a <em>fine art.</em></p>
      <p class='intro-body'>
        I'm a developer and designer who believes that software should feel
        effortless. I take deep dives into complex systems while maintaining a
        surface-level simplicity that delights users.
      </p>
      <ul class='platform-links'>
        {
          enabledLinks.map((link) => (
            <li>
              <SocialLink label={link.label} url={link.url} icon={link.icon} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <div class='spacer'></div>

  <!-- Story -->
  <section class='about-story' data-scroll-animate>
    <h2 class='section-title'>The Story</h2>
    <hr />
    <div class='story-body-container'>
      <div class='story-body-text'>
        <p class='story-lead'>
          I strip away the non-essential to focus on what truly matters:
          <strong>impact</strong>, <strong>clarity</strong>, and <strong
            >emotion</strong
          >.
        </p>
        <p>
          Whether it's a sleek dashboard or an immersive interactive experience,
          I bring a touch of alchemy to everything I build. My work lives at the
          intersection of engineering precision and creative expression — where
          code becomes craft.
        </p>
        <p>
          I'm drawn to projects that demand both technical depth and aesthetic
          sensibility. The best interfaces don't just work — they feel
          intentional, considered, inevitable.
        </p>
      </div>
      <div class='story-body-image-container'>
        <Picture class='story-body-image' src={testImg2} alt='test alt' />
      </div>
    </div>
  </section>

  <div class='spacer'></div>

  <!-- Expertise -->
  <section class='about-expertise'>
    <h2 class='section-title'>Expertise</h2>
    <hr />
    <div class='expertise-grid'>
      <article class='expertise-card' data-scroll-animate>
        <div class='expertise-icon'>
          <span class='ri-code-s-slash-line'></span>
        </div>
        <h3>Frontend Development</h3>
        <p>
          Building interfaces that feel alive with modern frameworks, reactive
          patterns, and meticulous attention to detail.
        </p>
        <ul class='tags'>
          <li>TypeScript</li>
          <li>Svelte</li>
          <li>Astro</li>
          <li>React</li>
        </ul>
      </article>
      <article class='expertise-card' data-scroll-animate>
        <div class='expertise-icon'>
          <span class='ri-palette-line'></span>
        </div>
        <h3>Design Systems</h3>
        <p>
          Creating cohesive visual languages that scale — from color theory and
          typography to component architecture.
        </p>
        <ul class='tags'>
          <li>SCSS</li>
          <li>Custom Properties</li>
          <li>OKLCH</li>
          <li>Figma</li>
        </ul>
      </article>
      <article class='expertise-card' data-scroll-animate>
        <div class='expertise-icon'>
          <span class='ri-sparkling-2-line'></span>
        </div>
        <h3>Creative Development</h3>
        <p>
          Pushing boundaries with animation, canvas rendering, and interactive
          experiences that surprise and delight.
        </p>
        <ul class='tags'>
          <li>Canvas API</li>
          <li>View Transitions</li>
          <li>CSS Animations</li>
          <li>WebGL</li>
        </ul>
      </article>
      <article class='expertise-card' data-scroll-animate>
        <div class='expertise-icon'>
          <span class='ri-shield-check-line'></span>
        </div>
        <h3>Quality & Craft</h3>
        <p>
          Ensuring every experience is fast, accessible, and built to last with
          semantic markup and performance-first thinking.
        </p>
        <ul class='tags'>
          <li>Accessibility</li>
          <li>Performance</li>
          <li>Semantic HTML</li>
          <li>SEO</li>
        </ul>
      </article>
    </div>
  </section>

  <div class='spacer'></div>

  <!-- Philosophy -->
  <section class='about-philosophy'>
    <h2 class='section-title'>Philosophy</h2>
    <hr />
    <div class='philosophy-grid'>
      <div class='philosophy-item' data-scroll-animate>
        <span class='philosophy-number'>01</span>
        <h3>Simplicity is sophistication</h3>
        <p>
          The best solutions feel obvious in hindsight. I remove everything that
          doesn't serve the user until only what matters remains.
        </p>
      </div>
      <div class='philosophy-item' data-scroll-animate>
        <span class='philosophy-number'>02</span>
        <h3>Every pixel has purpose</h3>
        <p>
          Nothing is accidental. From spacing to color, every decision is
          intentional and every detail earns its place.
        </p>
      </div>
      <div class='philosophy-item' data-scroll-animate>
        <span class='philosophy-number'>03</span>
        <h3>Code is craft</h3>
        <p>
          Clean code isn't just functional — it's expressive. I write code that
          communicates intent and invites collaboration.
        </p>
      </div>
    </div>
  </section>

  <div class='spacer'></div>

  <!-- Connect -->
  <section class='about-connect' data-scroll-animate>
    <h2 class='section-title'>Connect</h2>
    <hr />
    <p class='connect-lead'>
      Interested in working together or just want to say hello?
    </p>
    <ul class='platform-links platform-links--center'>
      {
        enabledLinks.map((link) => (
          <li>
            <SocialLink label={link.label} url={link.url} icon={link.icon} />
          </li>
        ))
      }
    </ul>
    <div class='connect-cta'>
      <Button
        label='View My Work'
        link='/projects'
        variant='primary'
        icon='ri-arrow-right-line'
        iconPosition='right'
      />
      <Button
        label='Back Home'
        link='/'
        variant='secondary'
        icon='ri-home-line'
      />
    </div>
  </section>
</Base>

<style lang='scss'>
  /* --- Spacers --- */
  .spacer {
    margin-block: 4rem;
  }

  /* --- Scroll Animations --- */
  [data-scroll-animate] {
    opacity: 0;
    transform: translateY(1.5rem);

    transition:
      opacity 600ms ease-out,
      transform 600ms ease-out;
  }

  [data-scroll-animate].visible {
    opacity: 1;
    transform: translateY(0);
  }

  .expertise-grid [data-scroll-animate]:nth-child(2) {
    transition-delay: 80ms;
  }
  .expertise-grid [data-scroll-animate]:nth-child(3) {
    transition-delay: 160ms;
  }
  .expertise-grid [data-scroll-animate]:nth-child(4) {
    transition-delay: 240ms;
  }

  .philosophy-grid [data-scroll-animate]:nth-child(2) {
    transition-delay: 100ms;
  }
  .philosophy-grid [data-scroll-animate]:nth-child(3) {
    transition-delay: 200ms;
  }

  /* --- Shared --- */
  .text-accent {
    color: var(--clr-primary);
  }

  .platform-links {
    display: flex;
    gap: 0.75rem;

    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .platform-links--center {
    justify-content: center;
    margin-bottom: 2rem;
  }

  /* ===================== */
  /*    Intro Section      */
  /* ===================== */
  .about-intro {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;

    padding-top: 2rem;
    margin-top: 4rem;
  }

  .intro-image {
    max-width: 400px;
  }

  .intro-label {
    text-transform: uppercase;
    font-weight: 300;
    letter-spacing: 0.3ch;
    color: var(--clr-primary);
    font-size: 0.875rem;

    margin: 0 0 0.5rem;
  }

  .about-intro h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;

    margin: 0 0 1rem;
  }

  .intro-tagline {
    font-size: 1.5rem;
    font-weight: 300;

    margin: 1rem 0 0;
  }

  .intro-tagline em {
    font-style: italic;
    color: var(--clr-primary);
  }

  .intro-body {
    color: var(--clr-subtext-1);
    line-height: 1.7;

    margin: 1rem 0 0;
  }

  /* ===================== */
  /*    Story Section      */
  /* ===================== */
  .story-body-container {
    display: grid;
    grid-template-columns: 65ch auto;
    gap: 2rem;
  }

  .story-body-image-container {
    overflow: hidden;
    border-radius: 16pt;
  }

  .story-body-image {
    height: auto;
  }

  .story-lead {
    font-size: 1.35rem;
    font-weight: 300;
    line-height: 1.6;

    margin-top: 0;
  }

  .story-lead strong {
    color: var(--clr-primary);
    font-weight: 500;
  }

  .story-body p {
    color: var(--clr-subtext-1);
    line-height: 1.8;
  }

  /* ===================== */
  /*   Expertise Section   */
  /* ===================== */
  .expertise-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;

    margin-top: 2rem;
  }

  .expertise-card {
    padding: 2rem;

    border-radius: 12pt;
    background-color: var(--clr-surface-0);
    border: 1px solid var(--clr-surface-2);

    transition:
      border-color 300ms ease-out,
      background-color 300ms ease-out;
  }

  .expertise-card:hover {
    border-color: var(--clr-overlay-0);
    background-color: var(--clr-surface-1);
  }

  .expertise-icon {
    display: flex;
    align-items: center;
    justify-content: center;

    width: 3rem;
    height: 3rem;

    border-radius: 8pt;
    background-color: var(--clr-surface-2);

    color: var(--clr-primary);
    font-size: 1.5rem;

    margin-bottom: 1.25rem;
  }

  .expertise-card h3 {
    font-size: 1.25rem;
    font-weight: 600;

    margin-bottom: 0.75rem;
  }

  .expertise-card p {
    color: var(--clr-subtext-1);
    line-height: 1.6;
    font-size: 0.95rem;

    margin: 0 0 1.25rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;

    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tags li {
    padding: 0.25rem 0.75rem;

    border-radius: 2pt;
    background-color: var(--clr-surface-2);

    color: var(--clr-subtext-0);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02ch;
  }

  /* ===================== */
  /*  Philosophy Section   */
  /* ===================== */
  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;

    margin-top: 2rem;
  }

  .philosophy-item {
    padding: 1.5rem 0 1.5rem 1.5rem;
    border-left: 2px solid var(--clr-surface-2);
  }

  .philosophy-number {
    display: block;

    font-size: 2.5rem;
    font-weight: 200;
    line-height: 1;
    color: var(--clr-primary);
    opacity: 0.5;

    margin-bottom: 1rem;
  }

  .philosophy-item h3 {
    font-size: 1.15rem;
    font-weight: 600;

    margin-bottom: 0.75rem;
  }

  .philosophy-item p {
    color: var(--clr-subtext-1);
    line-height: 1.7;
    font-size: 0.95rem;

    margin: 0;
  }

  /* ===================== */
  /*   Connect Section     */
  /* ===================== */
  .about-connect {
    text-align: center;
    padding-bottom: 2rem;
  }

  .connect-lead {
    font-size: 1.25rem;
    color: var(--clr-subtext-1);

    margin-bottom: 1.5rem;
  }

  .connect-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  /* ===================== */
  /*      Responsive       */
  /* ===================== */
  @media (max-width: 768px) {
    .about-intro {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .intro-image {
      max-width: 260px;
      margin-inline: auto;
    }

    .platform-links:not(.platform-links--center) {
      justify-content: center;
    }

    .expertise-grid {
      grid-template-columns: 1fr;
    }

    .philosophy-grid {
      grid-template-columns: 1fr;
    }

    .connect-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
