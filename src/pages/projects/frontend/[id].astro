---
import { getCollection, render } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('frontendProjects');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const keywords = [
  ...(post.data.category ? [post.data.category] : []),
  ...(post.data.tags ? post.data.tags : []),
];
---

<PostLayout
  title={`${post.data.title} | Austin Hagel`}
  description={post.data.description}
  keywords={keywords}
  coverImage={post.data.coverImage}
  coverAlt={post.data.coverAlt}
  images={post.data.images}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  categoryBase='/projects/frontend/categories'
  tags={post.data.tags}
  tagsBase='/projects/frontend/tags'
  status={post.data.status}
  demoUrl={post.data.demoUrl}
  repositoryUrl={post.data.repositoryUrl}
  frontendmentorUrl={post.data.frontendmentorUrl}
>
  <Content />
</PostLayout>
