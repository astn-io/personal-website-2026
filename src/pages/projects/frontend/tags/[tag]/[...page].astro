---
import { getCollection } from 'astro:content';
import type { Page } from 'astro';
import Directory from '@layouts/Directory.astro';
import frontendProjectsBg from '@assets/images/frontend-projects-hero.jpg';
import { Collection } from '@scripts/types';
import slugify from '@scripts/slugify';

export async function getStaticPaths({ paginate }: any) {
  const projects = (await getCollection('frontendProjects')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  const tags = [...new Set(projects.flatMap((p) => p.data.tags ?? []))];

  return tags.flatMap((tag) => {
    const filtered = projects.filter((p) => p.data.tags?.includes(tag));
    return paginate(filtered, {
      params: { tag: slugify(tag) },
      props: { tagName: tag },
      pageSize: 5,
    });
  });
}

type Props = {
  page: Page;
  tagName: string;
};

const { page, tagName } = Astro.props;
---

<Directory
  page={page}
  pageTitle={`Frontend Projects - Tags - ${tagName} | Austin Hagel`}
  collection={Collection.frontendProjects}
  heroTitle={tagName}
  route='/projects/frontend'
  image={frontendProjectsBg}
  showFeatured={false}
/>
