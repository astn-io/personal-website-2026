---
import { getCollection } from 'astro:content';
import type { Page } from 'astro';
import Directory from '@layouts/Directory.astro';

export async function getStaticPaths({ paginate }: any) {
  const frontendProjects = (await getCollection('frontendProjects')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  const pages = frontendProjects;

  return paginate(pages, { pageSize: 5 });
}

type Props = {
  page: Page;
};

const { page } = Astro.props;
---

<Directory
  page={page}
  collection='frontendProjects'
  heroTitle='Frontend Projects'
/>
